	<!-- اسکریپت فرمت خودکار تاریخ شمسی -->
	<script>
        $(document).ready(function () {
            const input = $("#PersianBirthDateStringify");

            // اگر در حالت ویرایش هستیم و مقدار قبلی هست → فرمت کن
            @if (Model.IsUpdating && !string.IsNullOrEmpty(Model.PersianBirthDateStringify))
            {
	            var clean = Model.PersianBirthDateStringify.Replace("/", "").Replace("-", "");
	            if (clean.Length == 8)
	            {
		            var formatted = clean.Substring(0,4) + "/" + clean.Substring(4,2) + "/" + clean.Substring(6,2);
		            <text>
                    input.val("@formatted");
                    </text>
	            }
            }

            // رویداد تایپ کاربر
            input.on("input", function () {
                let value = this.value.replace(/\D/g, ""); // فقط عدد

                if (value.length >= 4) {
                    value = value.substring(0, 4) + "/" + value.substring(4);
                }
                if (value.length >= 7) {
                    value = value.substring(0, 7) + "/" + value.substring(7, 10);
                }
                if (value.length > 10) {
                    value = value.substring(0, 10);
                }

                this.value = value;
            });

            // وقتی کاربر فوکوس رو از دست داد، اگر ناقص بود پاک کن (اختیاری)
            input.on("blur", function () {
                const val = this.value;
                if (val.length > 0 && val.length < 10) {
                    this.value = "";
                }
            });
        });
    </script>

	<!-- اسکریپت آپلود تصویر -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const input = document.getElementById("attachment_files");
            const list = document.getElementById("attachment_list");
            const message = document.getElementById("attachment_message");
            const maxFiles = 1;
            const maxSize = 2 * 1024 * 1024;
            const allowedTypes = ["image/jpeg", "image/jpg", "image/png", "image/webp"];
            let files = [];

            function updateList() {
                list.innerHTML = "";
                files.forEach((file, index) => {
                    const item = document.createElement("div");
                    item.className = "d-flex align-items-center bg-light rounded px-3 py-2 gap-2";
                    const img = document.createElement("img");
                    img.src = URL.createObjectURL(file);
                    img.style.width = "40px";
                    img.style.height = "40px";
                    img.style.objectFit = "cover";
                    img.style.borderRadius = "8px";
                    item.appendChild(img);
                    const name = document.createElement("span");
                    name.textContent = file.name;
                    name.className = "fs-7 text-gray-700 me-2";
                    item.appendChild(name);
                    const remove = document.createElement("button");
                    remove.type = "button";
                    remove.innerHTML = "×";
                    remove.className = "btn btn-icon btn-sm btn-danger";
                    remove.style.width = "28px";
                    remove.style.height = "28px";
                    remove.onclick = () => {
                        files.splice(index, 1);
                        updateList();
                        showMessage("فایل حذف شد", "danger");
                    };
                    item.appendChild(remove);
                    list.appendChild(item);
                });
            }

            function showMessage(text, type = "success") {
                message.innerHTML = `<small class="text-${type === "success" ? "success" : "danger"}">${text}</small>`;
                setTimeout(() => message.innerHTML = "", 3000);
            }

            input.addEventListener("change", function () {
                const newFiles = Array.from(this.files);
                if (newFiles.length === 0) return;
                const file = newFiles[0];
                if (files.length >= maxFiles) {
                    showMessage("فقط یک تصویر مجاز است!", "danger");
                    return;
                }
                if (!allowedTypes.includes(file.type)) {
                    showMessage("فقط فایل تصویری مجاز است!", "danger");
                    return;
                }
                if (file.size > maxSize) {
                    showMessage("حجم فایل بیش از ۲ مگابایت است!", "danger");
                    return;
                }
                files = [file];
                updateList();
                showMessage("تصویر با موفقیت انتخاب شد");
                this.value = "";
            });

            const form = document.querySelector("form");
            form.addEventListener("submit", function () {
                if (files.length > 0) {
                    const dataTransfer = new DataTransfer();
                    files.forEach(f => dataTransfer.items.add(f));
                    input.files = dataTransfer.files;
                }
            });
        });
    </script>
}
