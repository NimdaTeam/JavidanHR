@using _0_Framework.FileUploader
@using HrSystem.Application.common.Extensions
@using HrSystem.Domain.Entities
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using _0_Framework.Utilities.Helpers
@using AuthenticationSystem.SystemPermissions
@inject IFileUploadService _FileUploadService
@model HrSystem.Application.DTO.Step1PersonalVM

@{
    ViewData["Title"] = !Model.IsUpdating ? "ایجاد کارمند جدید - مرحله اطلاعات هویتی" : $"ویرایش اطلاعات هویتی کارمند: {ViewData["EmployeeTitle"]}";
}

<link rel="stylesheet" href="https://unpkg.com/persian-datepicker@latest/dist/css/persian-datepicker.min.css" />

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">@((Model.IsUpdating) ? $"اطلاعات هویتی کارمند: {ViewData["EmployeeTitle"]}" : "ایجاد کارمند جدید")</span>
            <span class="text-muted fw-semibold fs-6">مرحله ۱ از ۵ - اطلاعات هویتی</span>
        </h3>
    </div>

    <div class="card-body py-3">

        @if (!Model.IsUpdating)
        {
            <div class="alert alert-info text-center">
                <strong>لطفاً اطلاعات پایه کارمند را وارد کنید. این مرحله اجباری است و پس از ثبت، می‌توانید سایر بخش‌ها را بعداً تکمیل کنید.</strong>
            </div>
        }

        <form asp-action="AddEmployee" asp-controller="Employee" method="post" enctype="multipart/form-data" class="form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" value="@Model.Id" />
            <input type="hidden" asp-for="IsUpdating" value="@Model.IsUpdating" />

            <div class="row">

                <!-- کد کارمندی -->
                <div class="col-md-12">
                    <div class="fv-row mb-7">
                        <label class="required fw-bold fs-6 mb-2">کد کارمندی</label>
                        <input required asp-for="EmployeeCode" type="text" class="form-control form-control-solid text-center" placeholder="کد کارمندی" />
                        <span asp-validation-for="EmployeeCode" class="text-danger"></span>
                    </div>
                </div>

                <!-- نام -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="required fw-bold fs-6 mb-2">نام</label>
                        <input required asp-for="FirstName" type="text" class="form-control form-control-solid text-center" placeholder="نام" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                </div>

                <!-- نام خانوادگی -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="required fw-bold fs-6 mb-2">نام خانوادگی</label>
                        <input required asp-for="LastName" type="text" class="form-control form-control-solid text-center" placeholder="نام خانوادگی" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <!-- کد ملی -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="required fw-bold fs-6 mb-2">کد ملی</label>
                        <input required asp-for="NationalCode" type="text" maxlength="10" class="form-control form-control-solid ltr text-center" placeholder="کد ملی (۱۰ رقم)" />
                        <span asp-validation-for="NationalCode" class="text-danger"></span>
                    </div>
                </div>

                <!-- تاریخ تولد - شمسی با تبدیل به میلادی -->
                <div class="col-md-6">
	                <div class="fv-row mb-7">
		                <label class="required fw-bold fs-6 mb-2">تاریخ تولد (شمسی)</label>
		                <input required 
		                       type="text" 
		                       asp-for="PersianBirthDateStringify" 
                               id="PersianBirthDateStringify"
		                       class="form-control form-control-solid text-center" 
		                       placeholder="@($"مثلا: {DateTime.Now.ToShamsi()}")" 
		                       maxlength="10"
		                       autocomplete="off"
		                       dir="ltr" />
		                <span asp-validation-for="PersianBirthDateStringify" class="text-danger"></span>
		                <small class="text-muted d-block mt-1">فقط عدد تایپ کنید، اسلش خودکار اضافه می شود</small>
	                </div>
                </div>

                <!-- جنسیت -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="required fw-bold fs-6 mb-2">جنسیت</label>
                        <select required asp-for="Gender" class="form-select form-select-solid text-center"
                                asp-items="@(new SelectList(Enum.GetValues(typeof(Gender)).Cast<Gender>().Select(g => new SelectListItem { Value = ((int)g).ToString(), Text = g.ToPersian() }), "Value", "Text"))">
                            <option value="">انتخاب کنید</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <!-- وضعیت تأهل -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="required fw-bold fs-6 mb-2">وضعیت تأهل</label>
                        <select required asp-for="MaritalStatus" class="form-select form-select-solid text-center"
                                asp-items="@(new SelectList(Enum.GetValues(typeof(MaritalStatus)).Cast<MaritalStatus>().Select(m => new SelectListItem { Value = ((int)m).ToString(), Text = m.ToPersian() }), "Value", "Text"))">
                            <option value="">انتخاب کنید</option>
                        </select>
                        <span asp-validation-for="MaritalStatus" class="text-danger"></span>
                    </div>
                </div>

                <!-- تعداد فرزندان -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="fw-bold fs-6 mb-2">تعداد فرزندان</label>
                        <input asp-for="ChildrenCount" type="number" min="0" class="form-control form-control-solid text-center" placeholder="تعداد فرزندان" />
                    </div>
                </div>

                <!-- تصویر کارمند فعلی -->
                @if (!string.IsNullOrEmpty(Model.CurrentImage))
                {
                    <div class="fv-row mb-6 text-center">
                        <label class="fs-6 fw-semibold mb-3 d-block">تصویر فعلی</label>
                        <img src="@_FileUploadService.GetFileUrl(Model.CurrentImage, "Employees")"
                             alt="تصویر فعلی کارمند"
                             class="rounded"
                             style="width: 120px; height: 120px; object-fit: cover; border: 3px solid #e4e6ef;" />
                    </div>
                }

                <div class="fv-row mb-8">
                    <label class="fs-6 fw-semibold mb-3">تصویر کارمند</label>

                    <div class="text-center">
                        <label class="btn btn-light btn-active-light-primary btn-sm px-6">
                            <i class="ki-duotone ki-folder-add fs-2"></i> افزودن تصویر کارمند
                            <input type="file" asp-for="ProfileImage" id="attachment_files" accept="image/*" class="d-none" />
                        </label>

                        <div id="attachment_list" class="mt-4 d-flex flex-wrap gap-3 justify-content-center"></div>
                        <div id="attachment_message" class="mt-3"></div>
                    </div>

                    <div class="form-text text-muted text-center">
                        حجم فایل حداکثر 2 مگابایت • فرمت: JPG, PNG, WebP
                    </div>
                </div>

            </div>

            <div class="text-center pt-10">
                <button type="submit" class="btn btn-primary">
                    <span class="indicator-label">ثبت کارمند</span>
                </button>
                <a permissions="[SystemPermissions.EmployeesList]" asp-action="AllEmployees" class="btn btn-light me-3">انصراف</a>
            </div>

        </form>
    </div>
</div>

