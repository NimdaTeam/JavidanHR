@using AuthenticationSystem.SystemPermissions
@using HrSystem.Domain.Entities
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model HrSystem.Application.DTO.Step2ContactVM
@{
    ViewData["Title"] = "تکمیل اطلاعات تماس";
    var employeeTitle = ViewData["EmployeeTitle"] as string ?? "کارمند";
}

<div class="card mb-5 mb-xl-8">
    <!--begin::Header-->
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">تکمیل اطلاعات تماس</span>
            <span class="text-muted fw-semibold fs-6">
	            کارمند: <strong>@employeeTitle</strong>
            </span>
        </h3>
        <div class="card-toolbar">
            <a permissions="[SystemPermissions.EmployeesList]" asp-action="AllEmployees" class="btn btn-sm btn-light">
                بازگشت به لیست
            </a>
        </div>
    </div>
    <!--end::Header-->
    <!--begin::Body-->
    <div class="card-body py-3">

        <div class="alert alert-info text-center">
            <strong>مرحله ۲ از ۵ - اطلاعات تماس و اضطراری</strong><br />
            این بخش اختیاری است اما برای ارتباط و موارد اضطراری بسیار مهم می‌باشد.
        </div>

        <!--begin::Form-->
        <form asp-action="AddContactInformationToEmployee" asp-route-employeeId="@Model.Id" method="post" class="form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row">

                <!-- شماره تماس -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="required fw-bold fs-6 mb-2">شماره همراه</label>
                        <input required="" asp-for="PhoneNumber" type="text" maxlength="11" class="form-control form-control-solid ltr text-center" placeholder="۰۹۱۲۳۴۵۶۷۸۹" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                </div>

                <!-- ایمیل -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="fw-bold fs-6 mb-2">ایمیل</label>
                        <input asp-for="Email" type="email" class="form-control form-control-solid ltr text-center" placeholder="example@domain.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <!-- آدرس -->
                <div class="col-12">
                    <div class="fv-row mb-7">
                        <label class="fw-bold fs-6 mb-2">آدرس محل سکونت</label>
                        <textarea asp-for="Address" rows="3" class="form-control form-control-solid" placeholder="آدرس کامل شامل استان، شهر، خیابان، پلاک و ..."></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>

                <!-- شخص ضروری در مواقع اضطرار -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="fw-bold fs-6 mb-2">نام و نام خانوادگی شخص ضروری</label>
                        <input asp-for="EmergencyContactName" type="text" class="form-control form-control-solid text-center" placeholder="مثلاً: علی محمدی (پدر)" />
                        <span asp-validation-for="EmergencyContactName" class="text-danger"></span>
                    </div>
                </div>

                <!-- شماره تماس اضطراری -->
                <div class="col-md-6">
                    <div class="fv-row mb-7">
                        <label class="fw-bold fs-6 mb-2">شماره همراه شخص ضروری</label>
                        <input asp-for="EmergencyContactPhone" type="text" maxlength="11" class="form-control form-control-solid ltr text-center" placeholder="۰۹۱۲۳۴۵۶۷۸۹" />
                        <span asp-validation-for="EmergencyContactPhone" class="text-danger"></span>
                    </div>
                </div>

            </div>
            <!--end::Row-->
            <!--begin::Actions-->
            <div class="text-center pt-10">
                <button type="submit" class="btn btn-primary btn-lg">
                    <span class="indicator-label">ذخیره اطلاعات تماس</span>
                </button>
                <a permissions="[SystemPermissions.EmployeesList]" asp-action="AllEmployees" class="btn btn-light btn-lg me-3">انصراف و بازگشت</a>
            </div>
            <!--end::Actions-->

        </form>
        <!--end::Form-->
    </div>
    <!--end::Body-->
</div>

@section Scripts {
 
    <script>
        $(document).ready(function () {
            // فقط برای شماره‌ها: فقط عدد و شروع با 09
            $("input[type='text']").on("change", function () {
                if ($(this).attr("maxlength") === "11") {
                    this.value = this.value.replace(/[^0-9]/g, '');
                    if (!this.value.startsWith("09") && this.value.length > 0) {
                        this.value = "";
                    }
                }
            });
        });
    </script>
}