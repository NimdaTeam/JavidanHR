@using AuthenticationSystem.SystemPermissions
@using HrSystem.Application.common.Extensions
@using HrSystem.Domain.Entities
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model HrSystem.Application.DTO.Step5AdditionalVM
@{
    ViewData["Title"] = "تکمیل اطلاعات تکمیلی";
    var employeeTitle = ViewData["EmployeeTitle"] as string ?? "کارمند";
}

<div class="card mb-5 mb-xl-8">
    <!--begin::Header-->
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">اطلاعات تکمیلی</span>
            <span class="text-muted fw-semibold fs-6">
                کارمند: <strong>@employeeTitle</strong>
            </span>
        </h3>
        <div class="card-toolbar">
            <a permissions="[SystemPermissions.EmployeesList]" asp-action="AllEmployees" class="btn btn-sm btn-light">
                بازگشت به لیست
            </a>
        </div>
    </div>
    <!--end::Header-->
    <!--begin::Body-->
    <div class="card-body py-6">

        <div class="alert alert-info text-center mb-7">
            <strong>مرحله ۵ از ۵ - اطلاعات تکمیلی و یادداشت‌ها</strong><br />
            این مرحله اختیاری است اما برای ارزیابی و مدیریت بهتر پرسنل مفید می‌باشد.
        </div>

        <!--begin::Form-->
        <form asp-action="AddAdditionalInformationToEmployee" asp-route-employeeId="@Model.Id" method="post" class="form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-8">

                <!-- شماره بیمه تأمین اجتماعی -->
                <div class="col-md-6">
                    <label class="fw-bold fs-6 mb-2">شماره بیمه تأمین اجتماعی</label>
                    <input asp-for="InsuranceNumber" type="text" maxlength="20" class="form-control form-control-solid text-center ltr" placeholder="مثلاً: ۱۲۳۴۵۶۷۸۹۰" />
                </div>

                <!-- وضعیت سلامت -->
                <div class="col-md-6">
                    <label class="fw-bold fs-6 mb-2">وضعیت سلامت</label>
                    <select asp-for="HealthStatus" class="form-select form-select-solid text-center searchable-select"
                            asp-items="@(new SelectList(Enum.GetValues(typeof(HealthStatus)).Cast<HealthStatus>().Select(h => new SelectListItem
                            { Value = ((int)h).ToString(), Text = h.ToPersian() }), "Value", "Text"))">
                        <option value="">انتخاب کنید</option>
                    </select>
                </div>

                <!-- سطح مهارت -->
                <div class="col-md-12">
	                <label class="fw-bold fs-6 mb-2">سطح مهارت</label>
	                <select asp-for="SkillLevel" class="form-select form-select-solid text-center searchable-select">
		                <option value="">انتخاب کنید</option>
		                <option value="مبتدی">مبتدی</option>
		                <option value="آشنا">آشنا</option>
		                <option value="متوسط">متوسط</option>
		                <option value="حرفه‌ای">حرفه‌ای</option>
		                <option value="کارشناس ارشد">کارشناس ارشد</option>
		                <option value="متخصص">متخصص</option>
		                <option value="خبره">خبره</option>
		                <option value="استاد">استاد</option>
	                </select>
                </div>

                <!-- دوره‌های آموزشی گذرانده -->
                <div class="col-12">
                    <label class="fw-bold fs-6 mb-2">دوره‌های آموزشی گذرانده</label>
                    <textarea asp-for="CompletedTrainings" rows="4" class="form-control form-control-solid" placeholder="هر دوره را در یک خط وارد کنید..."></textarea>
                </div>

                <!-- مدارک و گواهینامه‌ها -->
                <div class="col-12">
                    <label class="fw-bold fs-6 mb-2">مدارک و گواهینامه‌ها</label>
                    <textarea asp-for="Certificates" rows="4" class="form-control form-control-solid" placeholder="مثلاً: گواهینامه ICDL، گواهینامه مدیریت پروژه PMP و ..."></textarea>
                </div>

                <!-- پروژه‌های محول شده -->
                <div class="col-12">
                    <label class="fw-bold fs-6 mb-2">پروژه‌ها یا وظایف مهم محول شده</label>
                    <textarea asp-for="AssignedProjects" rows="4" class="form-control form-control-solid" placeholder="توضیح مختصر درباره پروژه‌های فعلی یا گذشته..."></textarea>
                </div>

                <!-- یادداشت و توضیحات -->
                <div class="col-12">
                    <label class="fw-bold fs-6 mb-2">یادداشت و توضیحات اضافی</label>
                    <textarea asp-for="Notes" rows="5" class="form-control form-control-solid" placeholder="هر نکته‌ای که لازم است مدیریت بداند..."></textarea>
                </div>

            </div>
            <!--end::Row-->
            <!--begin::Actions-->
            <div class="text-center mt-10">
                <button type="submit" class="btn btn-success btn-lg">
                    <span class="indicator-label">تکمیل و ذخیره نهایی اطلاعات</span>
                </button>
                <a permissions="[SystemPermissions.EmployeesList]" asp-action="AllEmployees" class="btn btn-light btn-lg me-3">انصراف و بازگشت به لیست</a>
            </div>
            <!--end::Actions-->

        </form>
        <!--end::Form-->
    </div>
    <!--end::Body-->
</div>



@section Scripts {
}