@using HrSystem.Application.common.Extensions
@using HrSystem.Domain.Entities
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using _0_Framework.Utilities.Helpers;
@using AuthenticationSystem.SystemPermissions
@model HrSystem.Application.DTO.Step3OrganizationalVM
@{
	ViewData["Title"] = "تکمیل اطلاعات سازمانی";
	var employeeTitle = ViewData["EmployeeTitle"] as string ?? "کارمند";
}

<div class="card mb-5 mb-xl-8">
	<!--begin::Header-->
	<div class="card-header border-0 pt-5">
		<h3 class="card-title align-items-start flex-column">
			<span class="card-label fw-bold fs-3 mb-1">اطلاعات سازمانی و استخدامی</span>
			<span class="text-muted fw-semibold fs-6">
				کارمند: <strong>@employeeTitle</strong>
			</span>
		</h3>
		<div class="card-toolbar">
			<a permissions="[SystemPermissions.EmployeesList]" asp-action="AllEmployees" class="btn btn-sm btn-light">
				بازگشت به لیست
			</a>
		</div>
	</div>
	<!--end::Header-->
	<!--begin::Body-->
	<div class="card-body py-3">

		<div class="alert alert-info text-center">
			<strong>مرحله ۳ از ۵ - اطلاعات سازمانی، تحصیلی و استخدامی</strong><br />
			این اطلاعات برای گزارش‌گیری، محاسبه سابقه و دسته‌بندی پرسنل ضروری است.
		</div>

		<!--begin::Form-->
		<form asp-action="AddOrganizationalInformationToEmployee" asp-route-employeeId="@Model.Id" method="post" class="form">
			@Html.AntiForgeryToken()
			<input asp-for="Id" type="hidden" />

			<div class="row">

				<!-- واحد سازمانی -->
				<div class="col-md-6">
					<div class="fv-row mb-7">
						<label class="required fw-bold fs-6 mb-2">واحد سازمانی</label>
						<input required asp-for="Department" type="text" class="form-control form-control-solid text-center" placeholder="مثلاً: امور اداری" />
						<span asp-validation-for="Department" class="text-danger"></span>
					</div>
				</div>

				<!-- پست سازمانی -->
				<div class="col-md-6">
					<div class="fv-row mb-7">
						<label class="required fw-bold fs-6 mb-2">پست سازمانی</label>
						<input required asp-for="Position" type="text" class="form-control form-control-solid  text-center" placeholder="مثلاً: صندوقدار" />
						<span asp-validation-for="Position" class="text-danger"></span>
					</div>
				</div>

				<!-- سطح تحصیلات -->
				<div class="col-md-6">
					<div class="fv-row mb-7">
						<label class="required fw-bold fs-6 mb-2">سطح تحصیلات</label>
						<select required asp-for="EducationLevel" class="form-select form-select-solid  text-center"
								asp-items="@(new SelectList(Enum.GetValues(typeof(EducationLevel)).Cast<EducationLevel>().Select(e => new SelectListItem
		{
			Value = ((int)e).ToString(),
			Text = e.ToPersian()
		}), "Value", "Text"))">
							<option value="">انتخاب کنید</option>
						</select>
						<span asp-validation-for="EducationLevel" class="text-danger"></span>
					</div>
				</div>

				<!-- رشته تحصیلی -->
				<div class="col-md-6">
					<div class="fv-row mb-7">
						<label class="fw-bold fs-6 mb-2">رشته تحصیلی</label>
						<input asp-for="FieldOfStudy" type="text" class="form-control form-control-solid  text-center" placeholder="مثلاً: مدیریت بازرگانی" />
						<span asp-validation-for="FieldOfStudy" class="text-danger"></span>
					</div>
				</div>

				<!-- نوع قرارداد -->
				<div class="col-md-6">
					<div class="fv-row mb-7">
						<label class="required fw-bold fs-6 mb-2">نوع قرارداد</label>
						<select required asp-for="ContractType" class="form-select form-select-solid  text-center"
								asp-items="@(new SelectList(Enum.GetValues(typeof(ContractType)).Cast<ContractType>().Select(c => new SelectListItem
		{
			Value = ((int)c).ToString(),
			Text = c.ToPersian()
		}), "Value", "Text"))">
							<option value="">انتخاب کنید</option>
						</select>
						<span asp-validation-for="ContractType" class="text-danger"></span>
					</div>
				</div>

				<!-- نوع همکاری -->
				<div class="col-md-6">
					<div class="fv-row mb-7">
						<label class="required fw-bold fs-6 mb-2">نوع همکاری</label>
						<select required asp-for="CooperationType" class="form-select form-select-solid  text-center"
								asp-items="@(new SelectList(Enum.GetValues(typeof(CooperationType)).Cast<CooperationType>().Select(c => new SelectListItem
		{
			Value = ((int)c).ToString(),
			Text = c.ToPersian()
		}), "Value", "Text"))">
							<option value="">انتخاب کنید</option>
						</select>
						<span asp-validation-for="CooperationType" class="text-danger"></span>
					</div>
				</div>

				<!-- تاریخ استخدام (شمسی) -->
				<div class="col-md-6">
					<div class="fv-row mb-7">
						<label class="required fw-bold fs-6 mb-2">تاریخ استخدام (شمسی)</label>
						<input required 
						       type="text"
							   asp-for="HireDatePersianStringify"
							   id="HireDatePersianStringify"
						       class="form-control form-control-solid text-center" 
						       placeholder="@($"مثلا: {DateTime.Now.ToShamsi()}")" 
						       maxlength="10"
						       autocomplete="off"
						       dir="ltr" />
						<span asp-validation-for="HireDatePersianStringify" class="text-danger"></span>
						<small class="text-muted d-block mt-1">فقط عدد تایپ کنید، اسلش خودکار اضافه می شود</small>
					</div>
				</div>

			</div>
			<!--end::Row-->
			<!--begin::Actions-->
			<div class="text-center pt-10">
				<button type="submit" class="btn btn-primary btn-lg">
					<span class="indicator-label">ذخیره اطلاعات سازمانی</span>
				</button>
				<a permissions="[SystemPermissions.EmployeesList]" asp-action="AllEmployees" class="btn btn-light btn-lg me-3">انصراف و بازگشت</a>
			</div>
			<!--end::Actions-->

		</form>
		<!--end::Form-->
	</div>
	<!--end::Body-->
</div>

@section Scripts {
	
	<script>
        $(document).ready(function () {
		const input = $("#HireDatePersianStringify");

            // اگر در حالت ویرایش هستیم و مقدار قبلی هست → فرمت کن
		@if ( !string.IsNullOrEmpty(Model.HireDatePersianStringify))
            {
										var clean = Model.HireDatePersianStringify.Replace("/", "").Replace("-", "");
	            if (clean.Length == 8)
	            {
		            var formatted = clean.Substring(0,4) + "/" + clean.Substring(4,2) + "/" + clean.Substring(6,2);
		            <text>
                    input.val("@formatted");
                    </text>
	            }
            }

            // رویداد تایپ کاربر
            input.on("input", function () {
                let value = this.value.replace(/\D/g, ""); // فقط عدد

                if (value.length >= 4) {
                    value = value.substring(0, 4) + "/" + value.substring(4);
                }
                if (value.length >= 7) {
                    value = value.substring(0, 7) + "/" + value.substring(7, 10);
                }
                if (value.length > 10) {
                    value = value.substring(0, 10);
                }

                this.value = value;
            });

            // وقتی کاربر فوکوس رو از دست داد، اگر ناقص بود پاک کن (اختیاری)
            input.on("blur", function () {
                const val = this.value;
                if (val.length > 0 && val.length < 10) {
                    this.value = "";
                }
            });
        });
    </script>
}