									{
										<div class="fw-bold d-flex align-items-center fs-5">
											@if (User.Claims.AsQueryable().FirstOrDefault(x => x.Type == "fullName") is not null)
											{
												@User.Claims.AsQueryable().FirstOrDefault(x => x.Type == "fullName")!.Value
											}

											@* <span class="badge badge-light-success fw-bold fs-8 px-2 py-1 ms-2">@User.Identity.</span> *@
										</div>
										<h5 class="fw-semibold text-muted text-hover-primary fs-7">@User.Identity.Name</h5>
									}
									
								</div>
								<!--end::کاربرname-->
							</div>
						</div>
