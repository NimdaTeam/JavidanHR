<!DOCTYPE html>

<html direction="rtl" dir="rtl" style="direction: rtl">
<!--begin::Head-->
<head>
	<partial name="_HeadMeta"/>
	<partial name="_HeadCssJs"/>
</head>
<!--end::Head-->
<!--begin::Body-->
<body id="kt_app_body" data-kt-app-layout="light-sidebar" data-kt-app-header-fixed="true" data-kt-app-sidebar-enabled="true" data-kt-app-sidebar-fixed="true" data-kt-app-sidebar-hoverable="true" data-kt-app-sidebar-push-header="true" data-kt-app-sidebar-push-toolbar="true" data-kt-app-sidebar-push-footer="true" data-kt-app-toolbar-enabled="true" class="app-default">
<!--begin::Theme mode setup on page load-->
<script>
		(() => {
			const ROOT = document.documentElement;
			if (!ROOT) return;

			const saved = localStorage.getItem("data-bs-theme");
			const attr = ROOT.getAttribute("data-bs-theme-mode");

			let mode = attr || saved || "light";

			if (mode === "system") {
				mode = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
			}

			ROOT.setAttribute("data-bs-theme", mode);
		})();
	</script>
<!--end::Theme mode setup on page load-->
	<!--begin::اپلیکیشن-->
	<div class="d-flex flex-column flex-root app-root" id="kt_app_root">
		<!--begin::Page-->
		<div class="app-page flex-column flex-column-fluid" id="kt_app_page">
			<!--begin::Header-->
			<partial name="_MobileMenu" />
			<!--end::Header-->
			<!--begin::Wrapper-->
			<div class="app-wrapper flex-column flex-row-fluid" id="kt_app_wrapper">
				<!--begin::Sidebar-->
				<partial name="_DesktopMenu" />
				<!--end::Sidebar-->
				<!--begin::اصلی-->
				<div class="app-main flex-column flex-row-fluid" id="kt_app_main">
					<div class="d-flex flex-column flex-column-fluid">
						<!--begin::Toolbar-->
						<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
							<!--begin::Toolbar container-->
							<div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
								<!--begin::Page title-->
								<div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
									<!--begin::Title-->
									<h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">@ViewData["title"]</h1>
									<!--end::Title-->
									<!--begin::Breadcrumb-->
									<ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
										<!--begin::item-->
										<li class="breadcrumb-item text-muted">
											<a href="/" class="text-muted text-hover-primary">خانه</a>
										</li>
										<!--end::item-->
										<!--begin::item-->
										<li class="breadcrumb-item">
											<span class="bullet bg-gray-500 w-5px h-2px"></span>
										</li>
										<!--end::item-->
										<!--begin::item-->
										<li class="breadcrumb-item text-muted">@ViewData["title"]</li>
										<!--end::item-->
									</ul>
									<!--end::Breadcrumb-->
								</div>
								<!--end::Page title-->
								<!--begin::Actions-->
								@await RenderSectionAsync("SearchBox", false)
								<!--end::Actions-->
							</div>
							<!--end::Toolbar container-->
						</div>
						<!--end::Toolbar-->
						<!--begin::Content-->
						<div id="kt_app_content" class="app-content flex-column-fluid">
							<!--begin::Content container-->
							<div id="kt_app_content_container" class="app-container container-fluid">

								@RenderBody()
							</div>
						</div>
					</div>
					<!--end::Content container-->
				</div>
				<!--end::Content-->
			</div>
			<!--end::Content wrapper-->
			<!--begin::Footer-->
			<div id="kt_app_footer" class="app-footer">
				<!--begin::Footer container-->
				<div class="app-container container-fluid d-flex flex-column flex-md-row flex-center flex-md-stack py-3">
					<!--begin::کپیright-->
					<div class="text-gray-900 order-2">
						<span class="text-muted fw-semibold me-1">طراحی و پشتیبانی سامانه </span>
						<a href="https://nimdateam.ir" target="_blank" class="text-gray-800 text-hover-primary">گروه برنامه نویسی نیمدا</a>
					</div>
					<!--end::کپیright-->
					<!--begin::Menu-->
					<ul class="menu menu-gray-600 menu-hover-primary fw-semibold order-1">
						<li class="menu-item">
							<a href="https://nimdateam.ir" target="_blank" class="menu-link px-2">درباره ی ما</a>
						</li>
						<li class="menu-item">
							<a href="tel:09397812171" target="_blank" class="menu-link px-2">ارتباط با ما</a>
						</li>

					</ul>
					<!--end::Menu-->
				</div>
				<!--end::Footer container-->
			</div>
			<!--end::Footer-->
		</div>
		<!--end:::اصلی-->
	</div>

	<div class="modal fade" id="StockInformationModal" tabindex="-1" aria-hidden="true" style="display: none;">
	</div>

	<!--end::Wrapper-->
	<!--end::اپلیکیشن-->
	<!--begin::کشوs-->
	<!--begin::فعالیتها drawer-->
	<partial name="_UserNotifications" />
	<!-- Chat Window  -->

	<div id="kt_drawer_chat" class="bg-body drawer drawer-end" data-kt-drawer="true" data-kt-drawer-name="chat" data-kt-drawer-activate="true" data-kt-drawer-overlay="true" data-kt-drawer-width="{default:'100%', 'md': '100%'}" data-kt-drawer-direction="end" data-kt-drawer-toggle="#kt_drawer_chat_toggle" data-kt-drawer-close="#kt_drawer_chat_close" style="width: 75% !important;">
	</div>

	<!--end::فعالیتها drawer-->
	<!--end::کشوs-->
	<!--begin::Scrolltop-->
	<div id="kt_scrolltop" class="scrolltop" data-kt-scrolltop="true">
		<i class="ki-outline ki-arrow-up"></i>
	</div>
	<!--end::Scrolltop-->
	<partial name="_BodyCssJs"/>
	@await RenderSectionAsync("scripts", false);
</body>
<!--end::Body-->
</html>