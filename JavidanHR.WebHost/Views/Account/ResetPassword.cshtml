@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "بازیابی رمز عبور";
    var phone = TempData["ForgotPhone"] as string ?? "نامشخص";
}

<link rel="stylesheet" href="/css/login.css" nonce="@Context.Items["ScriptNonce"]" />

<div class="login-overlay">
    <div class="login-card" style="padding-right:10px !important;padding-left:10px !important">

        <!-- لوگو و عنوان -->
        <div class="text-center mb-10">
            <img alt="Logo" src="/assets/media/logos/Javidan-logo.webp" style="height:110px" />
            <h1 class="mt-6 fw-bolder text-white" style="font-size:1.8rem;">بازیابی رمز عبور</h1>
        </div>
        <hr class="border-gray-300 opacity-50">

        <!-- بخش اولیه: نمایش شماره + وارد کردن OTP -->
        <div id="initialSection">
            <div class="text-center mb-10">
                <p class="text-white fw-semibold fs-5">کد ۴ رقمی ارسال شده به شماره زیر را وارد کنید:</p>
                <div class="fw-bold text-white fs-3 mt-3">@phone</div>
                <div class="text-white-50 fs-6 mt-2">این کد تا ۲ دقیقه معتبر است</div>
            </div>

            <div class="fv-row mb-8">
                <label class="form-label fw-bold text-white text-center d-block">کد یکبار مصرف</label>
                <div class="d-flex justify-content-center gap-3 mb-5" style="direction:ltr">
                    <input type="text" maxlength="1" class="form-control form-control-lg text-center fs-1 otp-input" />
                    <input type="text" maxlength="1" class="form-control form-control-lg text-center fs-1 otp-input" />
                    <input type="text" maxlength="1" class="form-control form-control-lg text-center fs-1 otp-input" />
                    <input type="text" maxlength="1" class="form-control form-control-lg text-center fs-1 otp-input" />
                </div>
                <input type="hidden" id="otpCode" />
                <button type="button" id="verifyOtpBtn" class="btn-lg login-btn-primary w-100" disabled>
                    اعتبارسنجی کد یکبار مصرف
                </button>
                <div class="text-center mt-4">
                    <span id="otpError" class="text-danger fw-bold fs-5"></span>
                </div>
            </div>
        </div>

        <!-- بخش موفقیت + فرم تغییر رمز (بعد از تأیید OTP نشون داده میشه) -->
        <div id="successSection" style="display:none;">
            <div class="text-center mb-10">
                <div class="text-success fw-bold fs-2 mb-4">
                    <i style="color:green" class="fa fa-check-circle fs-1"></i>
                    کد یکبار مصرف با موفقیت تأیید شد.
                </div>
                <div class="text-white fs-5">لطفاً رمز عبور جدید خود را وارد کنید</div>
            </div>
            <hr class="border-gray-300 opacity-50">

            <form method="post" asp-action="ResetPassword" id="resetPasswordForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="phoneNumber" value="@phone" />

                <!-- رمز جدید -->
                <div class="fv-row mb-6">
                    <label class="form-label fw-bold text-white mb-3">رمز عبور جدید (حداقل ۸ کاراکتر)</label>
                    <div class="position-relative">
                        <input type="password" name="newPassword" id="newPassword" class="form-control form-control-lg text-center" required minlength="8" autocomplete="new-password" />
                        <button type="button" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 password-toggle">
                            <i class="fa fa-eye fs-4 text-gray-400"></i>
                        </button>
                    </div>

                    <div class="mt-4 text-center">
                        <div class="d-flex justify-content-center gap-2 mb-3">
                            <div class="password-strength-bar" id="bar1"></div>
                            <div class="password-strength-bar" id="bar2"></div>
                            <div class="password-strength-bar" id="bar3"></div>
                            <div class="password-strength-bar" id="bar4"></div>
                        </div>
                        <span id="strengthText" class="fw-bold text-gray-600"></span>
                    </div>
                </div>

                <!-- تکرار رمز -->
                <div class="fv-row mb-10">
                    <label class="form-label fw-bold text-white mb-3">تکرار رمز عبور جدید</label>
                    <div class="position-relative">
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-control form-control-lg text-center" required autocomplete="new-password" />
                        <button type="button" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 password-toggle">
                            <i class="fa fa-eye fs-4 text-gray-400"></i>
                        </button>
                    </div>
                    <div class="text-center mt-3">
                        <span id="passwordError" class="text-danger fw-bold"></span>
                    </div>
                </div>

                <button type="submit" id="resetBtn" class="btn-lg login-btn-primary w-100" disabled>
                    <span class="indicator-label"> تغییر رمز عبور </span>
                    <span class="indicator-progress d-none">
                        در حال پردازش...
                        <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                    </span>
                </button>
            </form>
        </div>

        <!-- بازگشت به لاگین -->
        <div class="text-center mt-10">
            <a href="/Account/Login" class="text-white-50 fw-medium">بازگشت به ورود</a>
        </div>

        <!-- فوتر -->
        <div class="modern-footer" style="color:white">
	        طراحی و پشتیبانی توسط
	        <a class="forgot-password" href="https://nimdateam.ir" target="_blank">گروه برنامه‌نویسی نیمدا</a>
	        <span class="text-white-500">© 1404</span>
        </div>
    </div>
</div>

<!-- استایل‌ها -->
<style>
    .otp-input {
        width: 60px !important;
    }

    .password-strength-bar {
        width: 60px;
        height: 7px;
        background: #374151;
        border-radius: 4px;
        transition: all 0.4s;
    }

        .password-strength-bar.active.danger {
            background: #ef4444;
        }

        .password-strength-bar.active.warning {
            background: #f59e0b;
        }

        .password-strength-bar.active.success {
            background: #10b981;
        }
</style>

@section Scripts {
    <script nonce="@Context.Items["ScriptNonce"]">
        document.addEventListener('DOMContentLoaded', function () {
            const initialSection = document.getElementById('initialSection');
            const successSection = document.getElementById('successSection');
            const otpInputs = document.querySelectorAll('.otp-input');
            const otpCode = document.getElementById('otpCode');
            const verifyBtn = document.getElementById('verifyOtpBtn');
            const otpError = document.getElementById('otpError');
            const newPass = document.getElementById('newPassword');
            const confirmPass = document.getElementById('confirmPassword');
            const resetBtn = document.getElementById('resetBtn');
            const strengthText = document.getElementById('strengthText');
            const passwordError = document.getElementById('passwordError');
            const bars = [1,2,3,4].map(i => document.getElementById('bar'+i));
            let lastScore = 0;

            // OTP: جابجایی خودکار + فقط عدد
            otpInputs.forEach((input, i) => {
                input.addEventListener('input', () => {
                    input.value = input.value.replace(/\D/g, '');
                    if (input.value && i < 3) otpInputs[i+1].focus();
                    updateOtp();
                });
                input.addEventListener('keydown', e => {
                    if (e.key === 'Backspace' && !input.value && i > 0) otpInputs[i-1].focus();
                });
            });

            function updateOtp() {
                const code = Array.from(otpInputs).map(i => i.value).join('');
                otpCode.value = code;
                verifyBtn.disabled = code.length !== 4;
            }

            // تأیید کد OTP
            verifyBtn.addEventListener('click', async () => {
                const code = otpCode.value;
                const res = await fetch('/Account/VerifyForgotPasswordOtp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ phoneNumber: '@phone', otp: code })
                });
                const data = await res.json();

                if (data.success) {
                    initialSection.style.display = 'none';
                    successSection.style.display = 'block';
                    newPass.focus();
                } else {
                    otpError.textContent = data.message || 'کد اشتباه یا منقضی شده است';
                }
            });

            // نمایش/مخفی کردن رمز
            document.querySelectorAll('.password-toggle').forEach(btn => {
                btn.addEventListener('click', function () {
                    const input = this.closest('.position-relative').querySelector('input');
                    const icon = this.querySelector('i');
                    const isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    icon.classList.toggle('fa-eye', !isPassword);
                    icon.classList.toggle('fa-eye-slash', isPassword);
                });
            });

            // بررسی قدرت رمز
            async function checkStrength() {
                const pass = newPass.value.trim();
                bars.forEach(b => b.classList.remove('active', 'danger', 'warning', 'success'));
                strengthText.textContent = pass ? 'در حال بررسی...' : '';
                if (!pass) { lastScore = 0; updateButton(); return; }

                try {
                    const res = await fetch('/Account/CheckPasswordStrength', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                        body: JSON.stringify({ password: pass })
                    });
                    const data = await res.json();
                    const fill = data.score >= 85 ? 4 : data.score >= 70 ? 3 : data.score >= 50 ? 2 : 1;
                    bars.forEach((b, i) => { if (i < fill) b.classList.add('active', data.strengthClass); });
                    strengthText.textContent = data.message;
                    strengthText.className = `fw-bold ${data.strengthClass === 'success' ? 'text-success' : data.strengthClass === 'warning' ? 'text-warning' : 'text-danger'}`;
                    lastScore = data.score;
                    updateButton();
                } catch {
                    strengthText.textContent = 'خطا در بررسی';
                    lastScore = 0;
                    updateButton();
                }
            }

            function passwordsMatch() {
                return newPass.value && confirmPass.value && newPass.value === confirmPass.value;
            }

            function updateButton() {
                const valid = lastScore >= 70 && passwordsMatch() && newPass.value.length >= 8;
                resetBtn.disabled = !valid;

                if (newPass.value && !passwordsMatch()) {
                    passwordError.textContent = 'رمزهای عبور مطابقت ندارند';
                } else if (newPass.value && newPass.value.length < 8) {
                    passwordError.textContent = 'رمز عبور باید حداقل ۸ کاراکتر باشد';
                } else {
                    passwordError.textContent = '';
                }
            }

            newPass.addEventListener('input', checkStrength);
            confirmPass.addEventListener('input', updateButton);

            // لودینگ دکمه تغییر رمز
            document.getElementById('resetPasswordForm').addEventListener('submit', function(e) {
                if (resetBtn.disabled) {
                    e.preventDefault();
                    return false;
                }
                resetBtn.querySelector('.indicator-label').classList.add('d-none');
                resetBtn.querySelector('.indicator-progress').classList.remove('d-none');
                resetBtn.disabled = true;
            });

            // فوکوس اولیه روی اولین فیلد OTP
            otpInputs[0].focus();
        });
    </script>
}