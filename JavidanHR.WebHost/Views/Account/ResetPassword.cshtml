@{
	Layout = "_AccountLayout";
	ViewData["Title"] = "بازیابی رمز عبور";
	var phone = TempData["ForgotPhone"] as string ?? "نامشخص";
}

<link rel="stylesheet" href="/css/login.css" nonce="@Context.Items["ScriptNonce"]" asp-append-version="true" />

<div class="login-overlay">
	<div class="login-card">

		<!-- لوگو و عنوان -->
		<div class="text-center mb-10">
			<img alt="Logo" src="/assets/media/logos/Javidan-logo.webp" style="height:110px" />
			<h1 class="mt-6 fw-bolder text-white" style="font-size:1.8rem;">بازیابی رمز عبور</h1>
		</div>

		<hr class="border-gray-300 opacity-50">

		<!-- بخش ورود OTP -->
		<div id="initialSection">
			<div class="text-center mb-10">
				<p class="text-white fw-semibold fs-5">کد ۴ رقمی ارسال شده به شماره زیر را وارد کنید:</p>
				<div class="fw-bold text-white fs-3 mt-3">@phone</div>
				<div class="text-white-50 fs-6 mt-2">این کد تا ۲ دقیقه معتبر است</div>
			</div>

			<div class="mb-10">
				<label class="form-label fw-bold text-white text-center d-block mb-6">
					کد امنیتی ۴ رقمی خود را وارد کنید
				</label>

				<div class="phone-wrapper mx-auto" style="max-width: 380px;">
					<div class="phone-container otp-special" id="otpContainer" style="gap:16px;">
						<div class="phone-digit otp-box"></div>
						<div class="phone-digit otp-box"></div>
						<div class="phone-digit otp-box"></div>
						<div class="phone-digit otp-box"></div>
					</div>
				</div>

				<div class="text-center mt-4">
					<span id="otpError" class="text-danger small" style="display:none; font-weight:800;"></span>
				</div>
			</div>

			<button type="button" id="verifyOtpBtn" class="btn btn-lg login-btn-primary w-100" disabled>
				<span class="indicator-label">اعتبارسنجی کد</span>
				<span class="indicator-progress d-none">
					در حال بررسی...
					<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
				</span>
			</button>
		</div>

		<!-- بخش تغییر رمز (بعد از تأیید OTP نمایش داده می‌شود) -->
		<div id="successSection" style="display:none;">
			<div class="text-center mb-10">
				<div class="text-success fw-bold fs-2 mb-4">
					<i style="color:green" class="fa fa-check-circle fs-1"></i>
					کد با موفقیت تأیید شد
				</div>
				<div class="text-white fs-5">لطفاً رمز عبور جدید خود را وارد کنید</div>
			</div>

			<hr class="border-gray-300 opacity-50">

			<form method="post" asp-action="ResetPassword" id="resetPasswordForm">
				@Html.AntiForgeryToken()
				<input type="hidden" name="phoneNumber" value="@phone" />

				<!-- رمز جدید -->
				<div class="fv-row mb-6">
					<label class="form-label fw-bold text-white mb-3">رمز عبور جدید (حداقل ۸ کاراکتر)</label>
					<div class="position-relative">
						<input type="password" name="newPassword" id="newPassword"
							   class="form-control form-control-lg text-center"
							   required minlength="8" autocomplete="new-password" />
						<button type="button" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 password-toggle">
							<i class="fa fa-eye fs-4 text-gray-400"></i>
						</button>
					</div>

					<div class="mt-4 text-center">
						<div class="d-flex justify-content-center gap-2 mb-3">
							<div class="password-strength-bar" id="bar1"></div>
							<div class="password-strength-bar" id="bar2"></div>
							<div class="password-strength-bar" id="bar3"></div>
							<div class="password-strength-bar" id="bar4"></div>
						</div>
						<span id="strengthText" class="fw-bold text-gray-600"></span>
					</div>
				</div>

				<!-- تکرار رمز -->
				<div class="fv-row mb-10">
					<label class="form-label fw-bold text-white mb-3">تکرار رمز عبور جدید</label>
					<div class="position-relative">
						<input type="password" name="confirmPassword" id="confirmPassword"
							   class="form-control form-control-lg text-center"
							   required autocomplete="new-password" />
						<button type="button" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 password-toggle">
							<i class="fa fa-eye fs-4 text-gray-400"></i>
						</button>
					</div>
					<div class="text-center mt-3">
						<span id="passwordError" class="text-danger fw-bold"></span>
					</div>
				</div>

				<button type="submit" id="resetBtn" class="btn-lg login-btn-primary w-100" disabled>
					<span class="indicator-label">تغییر رمز عبور</span>
					<span class="indicator-progress d-none">
						در حال پردازش...
						<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
					</span>
				</button>
			</form>
		</div>

		<!-- فوتر و بازگشت -->
		<div class="text-center mt-10">
			<a href="/Login" class="text-white-50 fw-medium">بازگشت به صفحه ورود</a>
		</div>

		<div class="modern-footer text-white" style="margin-top:30px;">
			طراحی و پشتیبانی توسط
			<a class="forgot-password" href="https://nimdateam.ir" target="_blank">گروه برنامه‌نویسی نیمدا</a>
			<span>© ۱۴۰۴</span>
		</div>
	</div>
</div>

<!-- اینپوت مخفی برای مدیریت بهتر caret و تجربه کاربری -->
<input type="text"
	   id="hiddenOtpInput"
	   class="phone-hidden-input"
	   inputmode="numeric"
	   readonly
	   autofocus />

@section Scripts
{
	<script nonce="@Context.Items["ScriptNonce"]" asp-append-version="true">
		document.addEventListener('DOMContentLoaded', function () {

			// --------------------- متغیرهای OTP ---------------------
			const boxes = document.querySelectorAll('.otp-box');
			const hiddenInput = document.getElementById('hiddenOtpInput');
			const container = document.getElementById('otpContainer');
			const verifyBtn = document.getElementById('verifyOtpBtn');
			const otpError = document.getElementById('otpError');

			   const isTouchDevice =
				   'ontouchstart' in window ||
				   navigator.maxTouchPoints > 0;

			   if (isTouchDevice) {
				   hiddenInput.removeAttribute('readonly');
				   hiddenInput.setAttribute('inputmode', 'numeric');
			   }

			let otpDigits = [];

			// --------------------- رندر باکس‌های OTP ---------------------
			function renderOtp() {
				const len = otpDigits.length;

				boxes.forEach((box, i) => {
					const hasValue = !!otpDigits[i];
					box.textContent = otpDigits[i] || '';
					box.classList.toggle('filled', hasValue);
					box.classList.toggle('current', (hasValue && len < 4) || i === len);
				});

				verifyBtn.disabled = len !== 4;

				// نمایش خطا در صورت ناقص بودن
				otpError.style.display = (len > 0 && len < 4) ? 'block' : 'none';
				if (otpError.style.display === 'block') {
					otpError.textContent = 'لطفاً کد ۴ رقمی را کامل وارد کنید';
				}

				container.classList.remove('valid-all', 'invalid-all');
				if (len === 4) {
					container.classList.add('valid-all');
				} else if (len > 0) {
					container.classList.add('invalid-all');
				}
			}

			// --------------------- مدیریت کلیدها در input مخفی ---------------------
			hiddenInput.addEventListener('keydown', e => {
				if (e.key >= '0' && e.key <= '9') {
					e.preventDefault();
					if (otpDigits.length < 4) {
						otpDigits.push(e.key);
						renderOtp();
					}
					return;
				}

				if (e.key === 'Backspace') {
					e.preventDefault();
					otpDigits.pop();
					renderOtp();
					return;
				}

				// پشتیبانی از Paste
				if (e.ctrlKey && e.key.toLowerCase() === 'v') {
					e.preventDefault();
					navigator.clipboard.readText().then(text => {
						const cleaned = text.replace(/\D/g, '').slice(0, 4);
						otpDigits = cleaned.split('');
						renderOtp();
					});
					return;
				}

				e.preventDefault();
			});

			// کلیک روی باکس‌ها → فوکوس روی input مخفی
			boxes.forEach(box => {
				box.addEventListener('click', () => hiddenInput.focus());
			});


			// --------------------- اعتبارسنجی OTP ---------------------
			verifyBtn.addEventListener('click', async () => {
				if (otpDigits.length !== 4) return;

				verifyBtn.querySelector('.indicator-label').classList.add('d-none');
				verifyBtn.querySelector('.indicator-progress').classList.remove('d-none');
				verifyBtn.disabled = true;

				const code = otpDigits.join('');
				const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

				try {
					const res = await fetch('/Account/VerifyForgotPasswordOtp', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							'RequestVerificationToken': token
						},
						body: JSON.stringify({ phoneNumber: '@phone', otp: code })
					});

					const data = await res.json();

					if (data.success) {
						document.getElementById('initialSection').style.display = 'none';
						document.getElementById('successSection').style.display = 'block';
						document.getElementById('newPassword').focus();
					} else {
						otpError.textContent = data.message || 'کد اشتباه یا منقضی شده است';
						otpError.style.display = 'block';
						container.classList.add('invalid-all');
					}
				} catch {
					otpError.textContent = 'خطا در ارتباط با سرور';
					otpError.style.display = 'block';
				} finally {
					verifyBtn.querySelector('.indicator-label').classList.remove('d-none');
					verifyBtn.querySelector('.indicator-progress').classList.add('d-none');
					verifyBtn.disabled = otpDigits.length !== 4;
				}
			});

			// --------------------- بقیه کدها (تغییر رمز + قدرت رمز + ...) ---------------------
			const newPass = document.getElementById('newPassword');
			const confirmPass = document.getElementById('confirmPassword');
			const resetBtn = document.getElementById('resetBtn');
			const strengthText = document.getElementById('strengthText');
			const passwordError = document.getElementById('passwordError');
			const bars = [1,2,3,4].map(i => document.getElementById('bar'+i));

			let lastScore = 0;

			// نمایش/مخفی رمز
			document.querySelectorAll('.password-toggle').forEach(btn => {
				btn.addEventListener('click', function () {
					const input = this.closest('.position-relative').querySelector('input');
					const icon = this.querySelector('i');
					const isPassword = input.type === 'password';
					input.type = isPassword ? 'text' : 'password';
					icon.classList.toggle('fa-eye', !isPassword);
					icon.classList.toggle('fa-eye-slash', isPassword);
				});
			});

			async function checkStrength() {
				const pass = newPass.value.trim();
				bars.forEach(b => b.classList.remove('active', 'danger', 'warning', 'success'));
				strengthText.textContent = pass ? 'در حال بررسی...' : '';

				if (!pass) {
					lastScore = 0;
					updateButton();
					return;
				}

				try {
					const res = await fetch('/Account/CheckPasswordStrength', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
						},
						body: JSON.stringify({ password: pass })
					});
					const data = await res.json();

					const fill = data.score >= 85 ? 4 : data.score >= 70 ? 3 : data.score >= 50 ? 2 : 1;
					bars.forEach((b, i) => {
						if (i < fill) b.classList.add('active', data.strengthClass);
					});

					strengthText.textContent = data.message;
					strengthText.className = `fw-bold ${data.strengthClass === 'success' ? 'text-success' : data.strengthClass === 'warning' ? 'text-warning' : 'text-danger'}`;

					lastScore = data.score;
					updateButton();
				} catch {
					strengthText.textContent = 'خطا در بررسی';
					lastScore = 0;
					updateButton();
				}
			}

			function passwordsMatch() {
				return newPass.value && confirmPass.value && newPass.value === confirmPass.value;
			}

			function updateButton() {
				const valid = lastScore >= 70 && passwordsMatch() && newPass.value.length >= 8;
				resetBtn.disabled = !valid;

				if (newPass.value && !passwordsMatch()) {
					passwordError.textContent = 'رمزهای عبور مطابقت ندارند';
				} else if (newPass.value && newPass.value.length < 8) {
					passwordError.textContent = 'رمز عبور باید حداقل ۸ کاراکتر باشد';
				} else {
					passwordError.textContent = '';
				}
			}

			newPass.addEventListener('input', checkStrength);
			confirmPass.addEventListener('input', updateButton);

			// لودینگ دکمه نهایی
			document.getElementById('resetPasswordForm').addEventListener('submit', function(e) {
				if (resetBtn.disabled) {
					e.preventDefault();
					return false;
				}
				resetBtn.querySelector('.indicator-label').classList.add('d-none');
				resetBtn.querySelector('.indicator-progress').classList.remove('d-none');
				resetBtn.disabled = true;
			});

			// شروع اولیه
			renderOtp();
			hiddenInput.focus();
		});
	</script>
}
