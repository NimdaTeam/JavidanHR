@{
	Layout = "_AccountLayout";
	ViewData["Title"] = "تنظیم رمز عبور";
}

<link rel="stylesheet" href="/css/login.css" nonce="@Context.Items["ScriptNonce"]" />

<div class="login-overlay">
	<div class="login-card">

		<form class="form w-100" method="post" asp-action="SetPassword" id="setPasswordForm">
			@Html.AntiForgeryToken()

			<!-- لوگو و عنوان -->
			<div class="text-center mb-10">
				<img alt="Logo" src="/assets/media/logos/Javidan-logo.webp" style="height:110px" />
				<h1 class="mt-6 fw-bolder text-white" style="font-size:1.8rem;">
					تنظیم رمز عبور
				</h1>
			</div>

			<hr class="border-gray-300 opacity-50">

			<div class="text-center mb-10">
				<div class="text-white fw-semibold fs-5 mb-6">
					خوش آمدید! برای امنیت بیشتر، لطفاً یک رمز عبور قوی برای حساب خود انتخاب کنید.
				</div>
				<div class="text-white-50 fs-6" style="margin-top:-10px">این رمز برای ورود بعدی با نام کاربری و رمز استفاده می‌شود</div>
				<div class="fw-bold text-white fs-4 mb-2" style="margin-top:15px">شماره همراه وارد شده:  @ViewBag.PhoneNumber</div>
			</div>

			<!-- رمز عبور جدید -->
			<!-- رمز عبور جدید -->
			<div class="fv-row mb-6">
				<label class="form-label fw-bold text-white mb-3">رمز عبور جدید (حداقل ۸ کاراکتر)</label>
				<div class="position-relative">
					<input type="password"
						   name="newPassword"
						   id="newPassword"
						   class="form-control form-control-lg form-control-solid text-center"
						   placeholder="رمز عبور جدید را وارد نمایید"
						   required
						   minlength="8"
						   autocomplete="new-password" />
					<button type="button" id="toggleNewPass" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 z-index-2">
						<i class="fa fa-eye fs-4 text-gray-400"></i>
					</button>
				</div>

				<!-- نمایشگر زنده قدرت رمز -->
				<div class="mt-3 text-center">
					<div class="d-flex justify-content-center align-items-center gap-2 mb-2">
						<div class="password-strength-bar" id="bar1"></div>
						<div class="password-strength-bar" id="bar2"></div>
						<div class="password-strength-bar" id="bar3"></div>
						<div class="password-strength-bar" id="bar4"></div>
					</div>
					<span id="strengthText" class="fw-bold"> </span>
				</div>
			</div>

			<!-- تکرار رمز عبور -->
			<div class="fv-row mb-10">
				<label class="form-label fw-bold text-white mb-3">تکرار رمز عبور</label>
				<div class="position-relative">
					<input type="password"
						   name="confirmPassword"
						   id="confirmPassword"
						   class="form-control form-control-lg form-control-solid text-center"
						   placeholder="رمز عبور را دوباره وارد کنید"
						   required
						   minlength="6" />
					<button type="button" id="toggleConfirmPass" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 z-index-2">
						<i class="fa fa-eye fs-4 text-gray-400"></i>
					</button>
				</div>
				<div class="text-center mt-3">
					<span id="passwordError" class="text-danger small" style="display:none; font-weight:800;"></span>
				</div>
			</div>

			<!-- دکمه ثبت رمز -->
			<button type="submit" id="submitBtn" class="btn btn-lg login-btn-primary w-100 mb-6" disabled>
				<span class="indicator-label">ثبت رمز عبور</span>
				<span class="indicator-progress d-none">
					در حال ثبت...
					<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
				</span>
			</button>

			<div class="text-center" style="margin-top:20px">
				<a href="/Account/Logout" class="text-white-50 fw-medium">
					<i class="fa fa-sign-out-alt me-2"></i>
					خروج از حساب کاربری
				</a>
			</div>

			<!-- فوتر -->
			<div class="modern-footer" style="color:white; margin-top: 40px;">
				طراحی و پشتیبانی توسط
				<a class="forgot-password" href="https://nimdateam.ir" target="_blank">گروه برنامه‌نویسی نیمدا</a>
				<span class="text-white-500">© ۱۴۰۴</span>
			</div>
		</form>
	</div>
</div>


@section scripts
{
	<script nonce="@Context.Items["ScriptNonce"]">
		document.addEventListener('DOMContentLoaded', function () {
			const newPass = document.getElementById('newPassword');
			const confirmPass = document.getElementById('confirmPassword');
			const submitBtn = document.getElementById('submitBtn');
			const errorSpan = document.getElementById('passwordError');
			const strengthText = document.getElementById('strengthText');
			const bars = [
				document.getElementById('bar1'),
				document.getElementById('bar2'),
				document.getElementById('bar3'),
				document.getElementById('bar4')
			];
			const toggleNew = document.getElementById('toggleNewPass');
			const toggleConfirm = document.getElementById('toggleConfirmPass');

			let lastValidScore = 0; // برای ردیابی آخرین امتیاز معتبر

			// نمایش/مخفی کردن رمز
			toggleNew.addEventListener('click', () => {
				const type = newPass.type === 'password' ? 'text' : 'password';
				newPass.type = type;
				toggleNew.querySelector('i').classList.toggle('fa-eye', type === 'text');
				toggleNew.querySelector('i').classList.toggle('fa-eye-slash', type === 'password');
			});

			toggleConfirm.addEventListener('click', () => {
				const type = confirmPass.type === 'password' ? 'text' : 'password';
				confirmPass.type = type;
				toggleConfirm.querySelector('i').classList.toggle('fa-eye', type === 'text');
				toggleConfirm.querySelector('i').classList.toggle('fa-eye-slash', type === 'password');
			});

			// نمایش خطا
			function showError(msg) {
				errorSpan.textContent = msg;
				errorSpan.style.display = 'block';
			}

			function hideError() {
				errorSpan.style.display = 'none';
			}

			// چک کردن مطابقت رمزها
			function passwordsMatch() {
				return newPass.value && confirmPass.value && newPass.value === confirmPass.value;
			}

			// تابع اصلی فعال/غیرفعال کردن دکمه
			function updateSubmitButton() {
				const isStrong = lastValidScore >= 70;
				const isMatch = passwordsMatch();
				const isLongEnough = newPass.value.length >= 8;

				if (isStrong && isMatch && isLongEnough) {
					submitBtn.disabled = false;
					hideError();
				} else {
					submitBtn.disabled = true;

					if (!isLongEnough) {
						showError('رمز عبور باید حداقل ۸ کاراکتر باشد');
					} else if (!isMatch) {
						showError('رمزهای عبور مطابقت ندارند');
					}
					// اگر ضعیف باشه → خطا از strengthText میاد، اینجا فقط دکمه رو غیرفعال میکنیم
				}
			}

			// چک قدرت رمز — با API سرور
			async function updatePasswordStrength() {
				const pass = newPass.value.trim();

				// ریست نمایشگر
				bars.forEach(b => b.classList.remove('active', 'danger', 'warning', 'success'));
				strengthText.textContent = pass ? 'در حال بررسی...' : 'رمز عبور را وارد کنید';
				strengthText.className = 'fw-bold text-white-50';

				if (!pass) {
					lastValidScore = 0;
					updateSubmitButton();
					return;
				}

				try {
					const response = await fetch('/Account/CheckPasswordStrength', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
						},
						body: JSON.stringify({ password: pass })
					});

					const data = await response.json();

					// اعمال بارها
					let fillCount = 0;
					if (data.score >= 85) fillCount = 4;
					else if (data.score >= 70) fillCount = 3;
					else if (data.score >= 50) fillCount = 2;
					else fillCount = 1;

					bars.forEach((bar, i) => {
						if (i < fillCount) {
							bar.classList.add('active', data.strengthClass);
						}
					});

					strengthText.textContent = data.message;
					strengthText.className = `fw-bold ${
						data.strengthClass === 'success' ? 'text-success' :
						data.strengthClass === 'warning' ? 'text-warning' : 'text-danger'
					}`;

					// ذخیره آخرین امتیاز
					lastValidScore = data.score;

					// آپدیت دکمه
					updateSubmitButton();

				} catch (e) {
					strengthText.textContent = 'خطا در بررسی رمز';
					strengthText.className = 'fw-bold text-danger';
					lastValidScore = 0;
					updateSubmitButton();
				}
			}

			// رویدادها
			newPass.addEventListener('input', updatePasswordStrength);
			confirmPass.addEventListener('input', updateSubmitButton);
			newPass.addEventListener('focus', () => newPass.select());

			// لودینگ موقع ارسال
				document.getElementById('setPasswordForm').addEventListener('submit', function(e) {
			// اگر دکمه غیرفعاله یعنی یکی از شرایط (قدرت رمز یا مطابقت) رعایت نشده
			if (submitBtn.disabled) {
				e.preventDefault();
				return false;
			}

			// همه چی درسته → لودینگ رو نشون بده و فرم رو بفرست
			submitBtn.querySelector('.indicator-label').classList.add('d-none');
			submitBtn.querySelector('.indicator-progress').classList.remove('d-none');
			submitBtn.disabled = true;
		});

			// شروع
			newPass.focus();
			updateSubmitButton();
		});
	</script>
}