@{
	Layout = "_AccountLayout";
}
@model AuthenticationSystem.Domain.User.Users

<link rel="stylesheet" href="/css/login.css" nonce="@Context.Items["ScriptNonce"]" asp-append-version="true" />

<div class="login-overlay">
	<div class="login-card">

		<form class="form w-100" asp-action="OTPConfirmation" method="post" id="otpForm">
			@Html.AntiForgeryToken()
			<input type="hidden" name="phoneNumber" value="@Model.PhoneNumber" />

			<div class="text-center mb-10">
				<img alt="Logo" src="/assets/media/logos/Javidan-logo.webp" style="height:110px" />
				<h1 class="mt-6 fw-bolder text-white" style="font-size:1.8rem;">تأیید کد یکبار مصرف</h1>
			</div>

			<hr class="border-gray-300 opacity-50">

			<div class="text-center mb-10">
				<div class="text-white fw-semibold fs-5 mb-4">
					کد تأیید به شماره زیر ارسال شده است
				</div>
				<div class="fw-bold text-white fs-3 mb-6">@Model.PhoneNumber</div>

				<div class="d-flex justify-content-center align-items-center gap-3">
					<span class="text-white-50">شماره اشتباه است؟</span>
					<a href="/Login" class="text-primary fw-bold forgot-password">ویرایش شماره</a>
				</div>
			</div>

			<div class="mb-10">
				<label class="form-label fw-bold text-white text-center d-block mb-6">
					کد امنیتی ۴ رقمی خود را وارد کنید
				</label>

				<div class="phone-wrapper mx-auto" style="max-width: 380px;">
					<div class="phone-container otp-special" id="otpContainer" style="gap:16px;">
						<div class="phone-digit otp-box"></div>
						<div class="phone-digit otp-box"></div>
						<div class="phone-digit otp-box"></div>
						<div class="phone-digit otp-box"></div>
					</div>
				</div>

				<div class="text-center mt-4">
					<span id="otpError"
						  class="text-danger small"
						  style="display:none;font-weight:800;"></span>
				</div>
			</div>

			<div class="d-flex justify-content-center align-items-center gap-4 mb-10">
				<button type="button" id="resendBtn" class="btn btn-link p-0" disabled>
					<span class="forgot-password">ارسال مجدد کد</span>
				</button>
				<span id="timer" class="text-white-50 fw-medium">۱۲۰ ثانیه</span>
			</div>

			<button type="submit"
					id="submitOtp"
					class="btn btn-lg login-btn-primary w-100"
					disabled>
				<span class="indicator-label">تأیید و ورود</span>
				<span class="indicator-progress d-none">
					در حال بررسی...
					<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
				</span>
			</button>
		</form>

		<div class="modern-footer text-white" style="margin-top:30px;">
			طراحی و پشتیبانی توسط
			<a class="forgot-password" href="https://nimdateam.ir" target="_blank">
				گروه برنامه‌نویسی نیمدا
			</a>
			<span>© ۱۴۰۴</span>
		</div>
	</div>
</div>

<input type="text"
	   id="hiddenOtpInput"
	   class="phone-hidden-input"
	   inputmode="numeric"
	   readonly
	   autofocus />

@section scripts
{
	<script nonce="@Context.Items["ScriptNonce"]" asp-append-version="true">
		document.addEventListener('DOMContentLoaded', function () {

			const boxes = document.querySelectorAll('.otp-box');
			const hiddenInput = document.getElementById('hiddenOtpInput');
			const container = document.getElementById('otpContainer');

			const submitBtn = document.getElementById('submitOtp');
			const resendBtn = document.getElementById('resendBtn');
			const timerSpan = document.getElementById('timer');
			const otpError = document.getElementById('otpError');

			   const isTouchDevice =
				   'ontouchstart' in window ||
				   navigator.maxTouchPoints > 0;

			   if (isTouchDevice) {
				   hiddenInput.removeAttribute('readonly');
				   hiddenInput.setAttribute('inputmode', 'numeric');
			   }

			let otpDigits = [];
			let countdown = 120;

			function render() {
				const len = otpDigits.length;

				boxes.forEach((box, i) => {
					const hasValue = !!otpDigits[i];
					box.textContent = otpDigits[i] || '';

					box.classList.toggle('filled', hasValue);

					box.classList.toggle(
						'current',
						(hasValue && len < 4) || i === len
					);
				});

				submitBtn.disabled = len !== 4;

				otpError.style.display = len > 0 && len < 4 ? 'block' : 'none';
				if (otpError.style.display === 'block') {
					otpError.textContent = 'لطفاً کد ۴ رقمی را کامل وارد کنید';
				}

				container.classList.remove('valid-all', 'invalid-all');

				if (len === 4) {
					container.classList.add('valid-all');
				} else if (len > 0) {
					container.classList.add('invalid-all');
				}
			}

			hiddenInput.addEventListener('keydown', e => {

				if (e.key >= '0' && e.key <= '9') {
					e.preventDefault();
					if (otpDigits.length < 4) {
						otpDigits.push(e.key);
						render();
					}
					return;
				}

				if (e.key === 'Backspace') {
					e.preventDefault();
					otpDigits.pop();
					render();
					return;
				}

				if (e.ctrlKey && e.key === 'v') {
					e.preventDefault();
					navigator.clipboard.readText().then(t => {
						otpDigits = t.replace(/\D/g, '').slice(0, 4).split('');
						render();
					});
					return;
				}

				e.preventDefault();
			});

			boxes.forEach(b => b.addEventListener('click', () => hiddenInput.focus()));

			const timer = setInterval(() => {
				countdown--;
				timerSpan.textContent = `${countdown} ثانیه`;
				if (countdown <= 0) {
					clearInterval(timer);
					resendBtn.disabled = false;
					timerSpan.textContent = '';
				}
			}, 1000);

			resendBtn.addEventListener('click', function () {
				const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

				fetch('@Url.Action("ResendOtp", "Account")', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						'RequestVerificationToken': token
					},
					body: JSON.stringify({ phoneNumber: '@Model.PhoneNumber' })
				}).then(() => location.reload());
			});

			document.getElementById('otpForm').addEventListener('submit', function (e) {
				if (otpDigits.length !== 4) {
					e.preventDefault();
					return;
				}

				const hiddenCode = document.createElement('input');
				hiddenCode.type = 'hidden';
				hiddenCode.name = 'otpCode';
				hiddenCode.value = otpDigits.join('');
				this.appendChild(hiddenCode);

				submitBtn.querySelector('.indicator-label').classList.add('d-none');
				submitBtn.querySelector('.indicator-progress').classList.remove('d-none');
			});

			render();
			hiddenInput.focus();
		});
	</script>
}
