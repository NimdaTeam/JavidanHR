@model AuthenticationSystem.Domain.User.Users

@{
	ViewData["Title"] = "تغییر رمز عبور";
}

<div class="card mb-5 mb-xl-8">
	<!--begin::Header-->
	<div class="card-header border-0 pt-5">
		<h3 class="card-title align-items-start flex-column">
		</h3>
	</div>
	<!--end::Header-->
	<!--begin::Body-->
	<div class="card-body py-3">
		<form id="changePasswordForm" class="form" method="post" asp-action="ChangePassword" asp-controller="User">
			@Html.AntiForgeryToken()

			<!--begin::Heading-->
			<div class="mb-13 text-center">
				<h1 class="mb-3">تغییر رمز عبور</h1>
				<div class="text-muted fw-semibold fs-5">
					کاربر: <span class="fw-bold text-primary">@Model.FullName</span> (@Model.PhoneNumber)
				</div>
			</div>
			<!--end::Heading-->
			<!--begin::Current Password-->
			<div class="fv-row mb-8">
				<label class="required fw-semibold fs-6 mb-2">رمز عبور فعلی</label>
				<div class="position-relative">
					<input type="password" name="currentPassword" id="currentPassword"
						   class="form-control form-control-solid text-center" placeholder="رمز عبور فعلی را وارد کنید"
						   required autocomplete="current-password" />
					<button type="button" id="toggleCurrent" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 password-toggle">
						<i class="fa fa-eye fs-4 text-gray-400"></i>
					</button>
				</div>
			</div>
			<!--end::Current Password-->
			<!--begin::New Password-->
			<div class="fv-row mb-6">
				<label class="required fw-semibold fs-6 mb-2">رمز عبور جدید (حداقل ۸ کاراکتر)</label>
				<div class="position-relative">
					<input type="password" name="newPassword" id="newPassword"
						   class="form-control form-control-solid text-center" placeholder="رمز قوی وارد کنید"
						   required minlength="8" autocomplete="new-password" />
					<button type="button" id="toggleNew" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 password-toggle">
						<i class="fa fa-eye fs-4 text-gray-400"></i>
					</button>
				</div>

				<!-- Password Strength Indicator -->
				<div class="mt-4 text-center">
					<div class="d-flex justify-content-center gap-2 mb-3">
						<div class="password-strength-bar" id="bar1"></div>
						<div class="password-strength-bar" id="bar2"></div>
						<div class="password-strength-bar" id="bar3"></div>
						<div class="password-strength-bar" id="bar4"></div>
					</div>
					<span id="strengthText" class="fw-bold text-gray-600"></span>
				</div>
			</div>
			<!--end::New Password-->
			<!--begin::Confirm Password-->
			<div class="fv-row mb-10">
				<label class="required fw-semibold fs-6 mb-2">تکرار رمز عبور جدید</label>
				<div class="position-relative">
					<input type="password" name="confirmPassword" id="confirmPassword"
						   class="form-control form-control-solid text-center" placeholder="رمز را دوباره وارد کنید"
						   required minlength="8" />
					<button type="button" id="toggleConfirm" class="btn btn-icon position-absolute top-50 end-0 translate-middle-y me-3 password-toggle">
						<i class="fa fa-eye fs-4 text-gray-400"></i>
					</button>
				</div>
				<div class="text-center mt-3">
					<span id="passwordError" class="text-danger small" style="display:none; font-weight:800;"></span>
				</div>
			</div>
			<!--end::Confirm Password-->
			<!--begin::Actions-->
			<div class="text-center">
				<button type="submit" id="submitBtn" class="btn btn-primary" disabled>
					<span class="indicator-label">تغییر رمز عبور</span>
					<span class="indicator-progress d-none">
						در حال پردازش...
						<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
					</span>
				</button>
			</div>
			<!--end::Actions-->
		</form>
	</div>
</div>


<style>
	.password-strength-bar {
		width: 60px;
		height: 7px;
		background: #e9ecef;
		border-radius: 4px;
		transition: all 0.4s;
	}

		.password-strength-bar.active.danger {
			background: #ef4444;
		}

		.password-strength-bar.active.warning {
			background: #f59e0b;
		}

		.password-strength-bar.active.success {
			background: #10b981;
		}
</style>

@section Scripts {
	<script nonce="@Context.Items["ScriptNonce"]">
		document.addEventListener('DOMContentLoaded', function () {
			const currentPass = document.getElementById('currentPassword');
			const newPass = document.getElementById('newPassword');
			const confirmPass = document.getElementById('confirmPassword');
			const submitBtn = document.getElementById('submitBtn');
			const errorSpan = document.getElementById('passwordError');
			const strengthText = document.getElementById('strengthText');
			const bars = [1,2,3,4].map(i => document.getElementById('bar' + i));
			let lastScore = 0;

			// Toggle visibility
					document.querySelectorAll('.password-toggle').forEach(btn => {
			btn.addEventListener('click', function () {
				const input = this.closest('.position-relative').querySelector('input[type="password"], input[type="text"]');
				const icon = this.querySelector('i');

				if (!input) return;

				const isPassword = input.type === 'password';
				input.type = isPassword ? 'text' : 'password';
				icon.classList.toggle('fa-eye', !isPassword);
				icon.classList.toggle('fa-eye-slash', isPassword);
			});
		});

			function showError(msg) { errorSpan.textContent = msg; errorSpan.style.display = 'block'; }
			function hideError() { errorSpan.style.display = 'none'; }

			function passwordsMatch() {
				return newPass.value && confirmPass.value && newPass.value === confirmPass.value;
			}

			function updateButton() {
				const valid = lastScore >= 70 && passwordsMatch() && newPass.value.length >= 8;
				submitBtn.disabled = !valid;
				if (!valid && newPass.value && !passwordsMatch()) showError('رمزهای عبور مطابقت ندارند');
				else if (!valid && newPass.value.length < 8) showError('رمز عبور باید حداقل ۸ کاراکتر باشد');
				else hideError();
			}

			async function checkStrength() {
				const pass = newPass.value.trim();
				bars.forEach(b => b.classList.remove('active', 'danger', 'warning', 'success'));
				strengthText.textContent = pass ? 'در حال بررسی...' : 'رمز عبور را وارد کنید';
				strengthText.className = 'fw-bold text-gray-600';

				if (!pass) { lastScore = 0; updateButton(); return; }

				try {
					const res = await fetch('/Account/CheckPasswordStrength', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
						body: JSON.stringify({ password: pass })
					});
					const data = await res.json();

					const fill = data.score >= 85 ? 4 : data.score >= 70 ? 3 : data.score >= 50 ? 2 : 1;
					bars.forEach((b, i) => { if (i < fill) b.classList.add('active', data.strengthClass); });

					strengthText.textContent = data.message;
					strengthText.className = `fw-bold ${data.strengthClass === 'success' ? 'text-success' : data.strengthClass === 'warning' ? 'text-warning' : 'text-danger'}`;

					lastScore = data.score;
					updateButton();
				} catch { strengthText.textContent = 'خطا در بررسی'; lastScore = 0; updateButton(); }
			}

			newPass.addEventListener('input', checkStrength);
			confirmPass.addEventListener('input', updateButton);
			currentPass.addEventListener('input', updateButton);

			document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
				if (submitBtn.disabled) { e.preventDefault(); return false; }
				submitBtn.querySelector('.indicator-label').classList.add('d-none');
				submitBtn.querySelector('.indicator-progress').classList.remove('d-none');
				submitBtn.disabled = true;
			});

			newPass.focus();
		});
	</script>
}