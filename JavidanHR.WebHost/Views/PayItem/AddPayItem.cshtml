@using PayrollSystem.Domain.Entities.PayItem
@using PayrollSystem.Domain.Common
@model PayrollSystem.Application.DTOs.CreatePayItemDto
@{
    ViewData["Title"] = "افزودن عامل حقوقی جدید";
    var allCodesJson = System.Text.Json.JsonSerializer.Serialize(
        PayItemConstants.GetAllValidItems().Select(x => new { code = x.SystemCode, name = x.Name, group = x.Group })
    );
}

<form asp-action="AddPayItem" asp-controller="PayItem" method="post" id="addPayItemForm">
    <div class="card mb-5 mb-xl-8 pi-card-main">
        <div class="card-header pi-card-header">
            <div class="d-flex align-items-center gap-3">
                <div class="pi-icon-wrap">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div>
                    <h3 class="card-title mb-0 pi-title">@ViewData["Title"]</h3>
                    <span class="pi-subtitle">تعریف عامل جدید در سیستم حقوق و دستمزد</span>
                </div>
            </div>
            <Form-buttons return-url="@ViewBag.ReturnUrl"></Form-buttons>
        </div>

        <div class="card-body py-8 px-8">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
            {
                <div class="pi-alert-error mb-6">
                    <i class="fas fa-exclamation-circle pi-alert-icon"></i>
                    <div>
                        @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <!-- ═══════════════ بخش اول: اطلاعات پایه ═══════════════ -->
            <div class="pi-section-label">
                <span class="pi-section-num">۱</span>
                اطلاعات پایه
            </div>

            <div class="row g-5 mb-6">
                <div class="col-md-6">
                    <div class="pi-field">
                        <label class="pi-label required">نام عامل حقوقی</label>
                        <input asp-for="Name" class="pi-input" placeholder="مثال: حق نوبتکاری" required />
                        <span asp-validation-for="Name" class="pi-error-msg"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="pi-field">
                        <label class="pi-label required">کد سیستمی</label>
                        <input asp-for="SystemCode" id="systemCodeInput"
                               class="pi-input pi-input-mono"
                               required placeholder="مثال: PAY_SHIFT_BONUS"
                               oninput="this.value = this.value.toUpperCase()" />
                        <span asp-validation-for="SystemCode" class="pi-error-msg"></span>
                        <div class="pi-hint">
                            <code class="pi-code-hint">PAY_</code> مزایا &nbsp;·&nbsp;
                            <code class="pi-code-hint">DED_</code> کسورات &nbsp;·&nbsp;
                            <code class="pi-code-hint">INF_</code> اطلاعاتی
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ بخش دوم: تنظیمات ═══════════════ -->
            <div class="pi-section-label">
                <span class="pi-section-num">۲</span>
                تنظیمات عامل
            </div>

            <div class="row g-5 mb-6">
                <div class="col-md-4">
                    <div class="pi-field">
                        <label class="pi-label required">نوع عامل</label>
                        <select asp-for="Type"
                                asp-items="@(ViewBag.PayItemTypes as IEnumerable<SelectListItem>)"
                                class="pi-select" id="payItemType">
                        </select>
                        <span asp-validation-for="Type" class="pi-error-msg"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="pi-field">
                        <label class="pi-label required">نوع داده</label>
                        <select asp-for="DataType"
                                asp-items="@(ViewBag.PayItemDataTypes as IEnumerable<SelectListItem>)"
                                class="pi-select" id="payItemDataType"
                                onchange="toggleFormulaSection()">
                        </select>
                        <span asp-validation-for="DataType" class="pi-error-msg"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="pi-field">
                        <label class="pi-label">ترتیب نمایش</label>
                        <input type="number" asp-for="SortOrder" class="pi-input text-center" min="0" placeholder="0" />
                        <span asp-validation-for="SortOrder" class="pi-error-msg"></span>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ بخش سوم: ویژگی‌ها ═══════════════ -->
            <div class="pi-section-label">
                <span class="pi-section-num">۳</span>
                ویژگی‌ها
            </div>

            <div class="pi-toggles-grid mb-8">
                <label class="pi-toggle-card" for="isInsured">
                    <div class="pi-toggle-icon pi-toggle-blue"><i class="fas fa-shield-alt"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">مشمول بیمه</span>
                        <span class="pi-toggle-desc">کسر حق بیمه</span>
                    </div>
                    <div class="pi-toggle-switch">
                        <input class="pi-toggle-input" type="checkbox" asp-for="IsInsured" id="isInsured" />
                        <span class="pi-toggle-slider"></span>
                    </div>
                </label>

                <label class="pi-toggle-card" for="isTaxable">
                    <div class="pi-toggle-icon pi-toggle-orange"><i class="fas fa-receipt"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">مشمول مالیات</span>
                        <span class="pi-toggle-desc">کسر مالیات</span>
                    </div>
                    <div class="pi-toggle-switch">
                        <input class="pi-toggle-input" type="checkbox" asp-for="IsTaxable" id="isTaxable" />
                        <span class="pi-toggle-slider"></span>
                    </div>
                </label>

                <label class="pi-toggle-card" for="isEditable">
                    <div class="pi-toggle-icon pi-toggle-purple"><i class="fas fa-pen"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">قابل ویرایش</span>
                        <span class="pi-toggle-desc">توسط کاربر</span>
                    </div>
                    <div class="pi-toggle-switch">
                        <input class="pi-toggle-input" type="checkbox" asp-for="IsEditable" id="isEditable" checked />
                        <span class="pi-toggle-slider"></span>
                    </div>
                </label>

                <label class="pi-toggle-card" for="isActive">
                    <div class="pi-toggle-icon pi-toggle-green"><i class="fas fa-power-off"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">فعال</span>
                        <span class="pi-toggle-desc">وضعیت عامل</span>
                    </div>
                    <div class="pi-toggle-switch">
                        <input class="pi-toggle-input" type="checkbox" asp-for="IsActive" id="isActive" checked />
                        <span class="pi-toggle-slider"></span>
                    </div>
                </label>
            </div>

            <!-- ═══════════════ بخش فرمول ═══════════════ -->
            <div id="formulaSection" style="display:none;">
                <div class="pi-section-label">
                    <span class="pi-section-num"><i class="fas fa-function" style="font-size:0.75rem;"></i></span>
                    فرمول محاسباتی
                </div>

                <div class="pi-formula-wrapper">

                    <!-- ردیف اول: textarea + تاریخ -->
                    <div class="row g-5 mb-0">
                        <div class="col-md-8">
                            <label class="pi-label required">فرمول</label>
                            <div class="pi-editor-wrap">
                                <div class="pi-editor-bar">
                                    <span class="pi-editor-dot red"></span>
                                    <span class="pi-editor-dot yellow"></span>
                                    <span class="pi-editor-dot green"></span>
                                    <span class="pi-editor-lang">FORMULA</span>
                                </div>
                                <textarea asp-for="Formula" id="formulaInput"
                                          class="pi-editor-textarea"
                                          rows="4"
                                          placeholder="PAY_BASE * 0.25 + ATT_OVERTIME * 1.4"
                                          oninput="onFormulaChange()"></textarea>
                            </div>
                            <span asp-validation-for="Formula" class="pi-error-msg"></span>

                            <!-- وضعیت ولیدیشن -->
                            <div id="formulaValidationResult" class="pi-status-bar" style="display:none;">
                                <div id="formulaValidOk" class="pi-status pi-status-ok" style="display:none;">
                                    <i class="fas fa-check-circle"></i>
                                    <span id="formulaTestResult"></span>
                                </div>
                                <div id="formulaValidErr" class="pi-status pi-status-err" style="display:none;">
                                    <i class="fas fa-times-circle"></i>
                                    <span id="formulaErrorMsg"></span>
                                </div>
                                <div id="formulaValidWarn" class="pi-status pi-status-warn" style="display:none;">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    <span id="formulaWarnMsg"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="pi-label required">تاریخ شروع اعتبار</label>
                            <input type="date" asp-for="FormulaValidFromDate"
                                   class="pi-input text-center"
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="FormulaValidFromDate" class="pi-error-msg"></span>

                            <!-- راهنمای سریع -->
                            <div class="pi-formula-tips mt-4">
                                <div class="pi-tips-title"><i class="fas fa-lightbulb me-1"></i> عملگرها</div>
                                <div class="pi-tips-grid">
                                    <span class="pi-tip"><code>+</code> جمع</span>
                                    <span class="pi-tip"><code>-</code> تفریق</span>
                                    <span class="pi-tip"><code>*</code> ضرب</span>
                                    <span class="pi-tip"><code>/</code> تقسیم</span>
                                    <span class="pi-tip"><code>( )</code> گروه‌بندی</span>
                                    <span class="pi-tip"><code>Math.round()</code></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- انتخاب‌گر عوامل -->
                    <div class="pi-picker mt-6">
                        <div class="pi-picker-header">
                            <span class="pi-picker-title">
                                <i class="fas fa-database me-2 text-muted"></i>
                                انتخاب متغیر برای درج در فرمول
                            </span>
                            <div class="pi-search-wrap">
                                <i class="fas fa-search pi-search-icon"></i>
                                <input type="text" id="codeSearch"
                                       class="pi-search-input"
                                       placeholder="جستجو..."
                                       oninput="filterCodes(this.value)" />
                            </div>
                        </div>

                        <!-- تب‌ها -->
                        <div class="pi-tabs" id="codeGroupTabs">
                            <button type="button" class="pi-tab active" onclick="filterByGroup('all', this)">همه</button>
                            <button type="button" class="pi-tab pi-tab-info" onclick="filterByGroup('کارکرد', this)">
                                <i class="fas fa-clock me-1"></i>کارکرد
                            </button>
                            <button type="button" class="pi-tab pi-tab-success" onclick="filterByGroup('مزایا', this)">
                                <i class="fas fa-plus me-1"></i>مزایا
                            </button>
                            <button type="button" class="pi-tab pi-tab-danger" onclick="filterByGroup('کسورات', this)">
                                <i class="fas fa-minus me-1"></i>کسورات
                            </button>
                            <button type="button" class="pi-tab pi-tab-primary" onclick="filterByGroup('اطلاعاتی', this)">
                                <i class="fas fa-info me-1"></i>اطلاعاتی
                            </button>
                            <button type="button" class="pi-tab pi-tab-warning" onclick="filterByGroup('سفارشی', this)">
                                <i class="fas fa-star me-1"></i>سفارشی
                            </button>
                        </div>

                        <!-- گرید عوامل -->
                        <div id="codeGrid" class="pi-code-grid"></div>
                    </div>

                    <!-- پنل تست فرمول -->
                    <div id="formulaTestPanel" class="pi-test-panel" style="display:none;">
                        <div class="pi-test-header">
                            <i class="fas fa-vial me-2"></i>
                            تست فرمول با مقادیر دلخواه
                            <span class="pi-test-hint">مقادیر را وارد کنید و دکمه محاسبه را بزنید</span>
                        </div>
                        <div id="formulaVarInputs" class="pi-var-grid"></div>
                        <div class="d-flex align-items-center gap-3 mt-4">
                            <button type="button" class="pi-calc-btn" onclick="runFormulaTest()">
                                <i class="fas fa-play me-2"></i>محاسبه نتیجه
                            </button>
                            <button type="button" class="pi-reset-btn" onclick="resetTestInputs()">
                                <i class="fas fa-redo me-1"></i>صفر کردن
                            </button>
                        </div>
                        <div id="formulaTestOutput" class="pi-test-output" style="display:none;"></div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script>
        // ─────────────────────────────────────────────
        // داده‌ها
        // ─────────────────────────────────────────────
        const ALL_CODES = @Html.Raw(allCodesJson);

        const GROUP_META = {
            'کارکرد':   { cls: 'grp-info',    icon: 'fa-clock'        },
            'مزایا':    { cls: 'grp-success',  icon: 'fa-plus-circle'  },
            'کسورات':   { cls: 'grp-danger',   icon: 'fa-minus-circle' },
            'اطلاعاتی': { cls: 'grp-primary',  icon: 'fa-info-circle'  },
            'سفارشی':   { cls: 'grp-warning',  icon: 'fa-star'         },
        };

        const VALID_CODES_SET = new Set(ALL_CODES.map(x => x.code.toUpperCase()));

        let activeGroup  = 'all';
        let searchText   = '';
        let debounceTimer = null;

        // ─────────────────────────────────────────────
        // گرید عوامل
        // ─────────────────────────────────────────────
        function renderCodeGrid() {
            const grid = document.getElementById('codeGrid');
            grid.innerHTML = '';

            const filtered = ALL_CODES.filter(item => {
                const matchGroup  = activeGroup === 'all' || item.group === activeGroup;
                const matchSearch = !searchText ||
                    item.name.includes(searchText) ||
                    item.code.toLowerCase().includes(searchText.toLowerCase());
                return matchGroup && matchSearch;
            });

            if (filtered.length === 0) {
                grid.innerHTML = `
                    <div class="pi-empty">
                        <i class="fas fa-search-minus"></i>
                        <span>موردی یافت نشد</span>
                    </div>`;
                return;
            }

            filtered.forEach(item => {
                const meta = GROUP_META[item.group] || { cls: 'grp-secondary', icon: 'fa-tag' };
                const chip = document.createElement('div');
                chip.className = `pi-chip ${meta.cls}`;
                chip.title = 'کلیک برای درج در فرمول';
                chip.innerHTML = `
                    <i class="fas ${meta.icon} pi-chip-icon"></i>
                    <div class="pi-chip-body">
                        <span class="pi-chip-name">${item.name}</span>
                        <code class="pi-chip-code">${item.code}</code>
                    </div>`;
                chip.addEventListener('click', () => insertCodeAtCursor(item.code));
                grid.appendChild(chip);
            });
        }

        function filterByGroup(group, btn) {
            activeGroup = group;
            document.querySelectorAll('#codeGroupTabs .pi-tab').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            renderCodeGrid();
        }

        function filterCodes(val) {
            searchText = val;
            renderCodeGrid();
        }

        // ─────────────────────────────────────────────
        // درج در cursor
        // ─────────────────────────────────────────────
        function insertCodeAtCursor(code) {
            const ta    = document.getElementById('formulaInput');
            const start = ta.selectionStart;
            const end   = ta.selectionEnd;
            const val   = ta.value;
            const before = (start > 0 && val[start - 1] !== ' ') ? ' ' : '';
            const after  = (end < val.length && val[end] !== ' ') ? ' ' : '';
            ta.value = val.substring(0, start) + before + code + after + val.substring(end);
            ta.selectionStart = ta.selectionEnd = start + before.length + code.length + after.length;
            ta.focus();
            onFormulaChange();
        }

        // ─────────────────────────────────────────────
        // استخراج متغیرها
        // ─────────────────────────────────────────────
        function extractVars(formula) {
            const matches = formula.match(/\b([A-Z][A-Z0-9_]*)\b/g) || [];
            return [...new Set(matches.map(v => v.toUpperCase()))];
        }

        function escapeRegex(s) {
            return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }

        // ─────────────────────────────────────────────
        // ولیدیشن ساختاری
        // ─────────────────────────────────────────────
        function onFormulaChange() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(_doValidate, 350);
        }

        function _doValidate() {
            const formula   = document.getElementById('formulaInput').value.trim();
            const resultDiv = document.getElementById('formulaValidationResult');
            const testPanel = document.getElementById('formulaTestPanel');
            const testOut   = document.getElementById('formulaTestOutput');

            // پاک‌سازی
            hideAll();
            resultDiv.style.display = 'none';
            testPanel.style.display = 'none';
            testOut.style.display   = 'none';

            if (!formula) return;

            resultDiv.style.display = 'block';

            const vars        = extractVars(formula);
            const invalidVars = vars.filter(v => !VALID_CODES_SET.has(v));

            if (vars.length === 0) {
                showWarn('فرمول باید حداقل شامل یک متغیر (عامل حقوقی) باشد');
                return;
            }
            if (invalidVars.length > 0) {
                showError(`کدهای ناشناخته: <strong>${invalidVars.join('، ')}</strong>`);
                return;
            }

            // بررسی ساختاری با مقدار ۱
            let testFormula = formula;
            vars.forEach(v => {
                testFormula = testFormula.replace(new RegExp(`\\b${escapeRegex(v)}\\b`, 'gi'), '(1)');
            });

            try {
                // eslint-disable-next-line no-new-func
                const result = new Function('"use strict"; return (' + testFormula + ')')();
                if (typeof result !== 'number' || isNaN(result)) {
                    showError('فرمول مقدار عددی برنمی‌گرداند');
                    return;
                }
                if (!isFinite(result)) {
                    showWarn('احتمال تقسیم بر صفر — مقادیر را در پنل تست بررسی کنید');
                } else {
                    showOk('ساختار فرمول صحیح است');
                }
                buildTestPanel(vars);
                testPanel.style.display = 'block';
            } catch (e) {
                showError(`خطای ساختاری: ${friendlyError(e.message)}`);
            }
        }

        function hideAll() {
            ['formulaValidOk','formulaValidErr','formulaValidWarn'].forEach(id => {
                document.getElementById(id).style.display = 'none';
            });
        }
        function showOk(msg) {
            const el = document.getElementById('formulaValidOk');
            document.getElementById('formulaTestResult').textContent = msg;
            el.style.display = 'flex';
        }
        function showError(msg) {
            const el = document.getElementById('formulaValidErr');
            document.getElementById('formulaErrorMsg').innerHTML = msg;
            el.style.display = 'flex';
        }
        function showWarn(msg) {
            const el = document.getElementById('formulaValidWarn');
            document.getElementById('formulaWarnMsg').textContent = msg;
            el.style.display = 'flex';
        }

        function friendlyError(msg) {
            if (msg.includes('Unexpected token') || msg.includes('expected expression')) return 'عبارت ناقص یا پرانتز اشتباه';
            if (msg.includes('is not defined')) return 'متغیر تعریف‌نشده';
            if (msg.includes('Invalid'))        return 'عبارت نامعتبر';
            return msg;
        }

        // ─────────────────────────────────────────────
        // پنل تست
        // ─────────────────────────────────────────────
        function buildTestPanel(vars) {
            const container = document.getElementById('formulaVarInputs');
            // مقادیر قبلی را نگه دار
            const oldVals = {};
            container.querySelectorAll('.pi-var-input').forEach(inp => {
                oldVals[inp.dataset.var] = inp.value;
            });

            container.innerHTML = '';
            vars.forEach(v => {
                const info  = ALL_CODES.find(x => x.code.toUpperCase() === v);
                const label = info ? info.name : v;
                const meta  = info ? (GROUP_META[info.group] || {}) : {};
                const prevVal = oldVals[v] ?? '0';

                const wrap = document.createElement('div');
                wrap.className = 'pi-var-item';
                wrap.innerHTML = `
                    <label class="pi-var-label">
                        <i class="fas ${meta.icon || 'fa-tag'} me-1 opacity-50"></i>${label}
                    </label>
                    <code class="pi-var-code">${v}</code>
                    <input type="number"
                           class="pi-var-input"
                           data-var="${v}"
                           value="${prevVal}"
                           step="any"
                           placeholder="0"
                           onkeydown="if(event.key==='Enter'){event.preventDefault();runFormulaTest();}" />`;
                container.appendChild(wrap);
            });
        }

        function runFormulaTest() {
            const formula = document.getElementById('formulaInput').value.trim();
            const output  = document.getElementById('formulaTestOutput');
            output.style.display = 'none';
            if (!formula) return;

            const inputs = document.querySelectorAll('.pi-var-input');
            let testFormula = formula;

            inputs.forEach(inp => {
                const val = parseFloat(inp.value);
                const num = isNaN(val) ? 0 : val;
                testFormula = testFormula.replace(
                    new RegExp(`\\b${escapeRegex(inp.dataset.var)}\\b`, 'gi'),
                    `(${num})`
                );
            });

            output.style.display = 'block';
            try {
                // eslint-disable-next-line no-new-func
                const result = new Function('"use strict"; return (' + testFormula + ')')();

                if (typeof result !== 'number' || isNaN(result)) {
                    output.innerHTML = `<div class="pi-result pi-result-err"><i class="fas fa-times-circle me-2"></i>فرمول مقدار عددی برنمی‌گرداند</div>`;
                    return;
                }
                if (!isFinite(result)) {
                    output.innerHTML = `<div class="pi-result pi-result-warn"><i class="fas fa-exclamation-triangle me-2"></i>تقسیم بر صفر — مقادیر متغیرها را بررسی کنید</div>`;
                    return;
                }

                const formatted = result.toLocaleString('fa-IR', { maximumFractionDigits: 4 });
                const exprClean = testFormula.replace(/\((\d+(\.\d+)?)\)/g, '$1');
                output.innerHTML = `
                    <div class="pi-result pi-result-ok">
                        <div class="pi-result-label">نتیجه محاسبه</div>
                        <div class="pi-result-value">${formatted}</div>
                        <div class="pi-result-expr" dir="ltr">${exprClean}</div>
                    </div>`;
            } catch (e) {
                output.innerHTML = `<div class="pi-result pi-result-err"><i class="fas fa-times-circle me-2"></i>خطا: ${friendlyError(e.message)}</div>`;
            }
        }

        function resetTestInputs() {
            document.querySelectorAll('.pi-var-input').forEach(inp => inp.value = '0');
            document.getElementById('formulaTestOutput').style.display = 'none';
        }

        // ─────────────────────────────────────────────
        // نمایش/مخفی بخش فرمول
        // ─────────────────────────────────────────────
        function toggleFormulaSection() {
            const dataType = parseInt(document.getElementById('payItemDataType').value);
            document.getElementById('formulaSection').style.display = (dataType === 2) ? 'block' : 'none';
        }

        // ─────────────────────────────────────────────
        // ولیدیشن submit
        // ─────────────────────────────────────────────
        document.getElementById('addPayItemForm').addEventListener('submit', function (e) {
            const dataType = parseInt(document.getElementById('payItemDataType').value);
            if (dataType !== 2) return;

            const formula = document.getElementById('formulaInput').value.trim();
            const errEl   = document.getElementById('formulaValidErr');

            if (!formula) {
                e.preventDefault();
                document.getElementById('formulaInput').classList.add('is-invalid');
                return;
            }
            if (errEl && errEl.style.display !== 'none') {
                e.preventDefault();
                errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });

        // ─────────────────────────────────────────────
        // راه‌اندازی اولیه
        // ─────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function () {
            renderCodeGrid();
            toggleFormulaSection();
            const formula = document.getElementById('formulaInput').value;
            if (formula) onFormulaChange();
        });
    </script>
}

