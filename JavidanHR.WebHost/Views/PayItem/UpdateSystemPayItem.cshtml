@using PayrollSystem.Domain.Common
@model PayrollSystem.Application.DTOs.UpdateSystemPayItemDto
@{
    ViewData["Title"] = $"تنظیمات عامل سیستمی: {Model.Name}";
    var allCodesJson = System.Text.Json.JsonSerializer.Serialize(
        PayItemConstants.GetAllValidItems().Select(x => new { code = x.SystemCode, name = x.Name, group = x.Group })
    );
}

<form asp-action="UpdateSystemPayItem" asp-controller="PayItem" method="post" id="editSystemForm">
    @Html.AntiForgeryToken()

    <div class="card mb-5 mb-xl-8 pi-card-main">
        <div class="card-header pi-card-header">
            <div class="d-flex align-items-center gap-3">
                <div class="pi-icon-wrap" style="background:rgba(255,200,0,.18)">
                    <i class="fas fa-cogs text-warning"></i>
                </div>
                <div>
                    <h3 class="card-title mb-0 pi-title">@ViewData["Title"]</h3>
                    <span class="pi-subtitle">
                        ویرایش محدود — نام، کد و نوع داده قابل تغییر نیستند
                    </span>
                </div>
            </div>
            <Form-buttons return-url="@Url.Action("AllPayItems")"></Form-buttons>
        </div>

        <div class="card-body py-8 px-8">

            @* Hidden fields *@
            <input type="hidden" asp-for="SystemCode" />
            <input type="hidden" asp-for="Name" />
            <input type="hidden" asp-for="TypeDisplay" />
            <input type="hidden" asp-for="DataTypeDisplay" />
            <input type="hidden" asp-for="HasDataTypeFormula" />
            <input type="hidden" asp-for="DefaultFormula" />

            @* ── اطلاعات ثابت (فقط نمایش) ── *@
            <div class="pi-section-label">
                <span class="pi-section-num"><i class="fas fa-lock" style="font-size:.6rem"></i></span>
                اطلاعات ثابت سیستمی
            </div>

            <div class="pi-readonly-banner mb-7">
                <div class="pi-readonly-item">
                    <span class="pi-readonly-lbl">نام عامل</span>
                    <span class="pi-readonly-val">@Model.Name</span>
                </div>
                <div class="pi-readonly-sep"></div>
                <div class="pi-readonly-item">
                    <span class="pi-readonly-lbl">کد سیستمی</span>
                    <code class="pi-readonly-code">@Model.SystemCode</code>
                </div>
                <div class="pi-readonly-sep"></div>
                <div class="pi-readonly-item">
                    <span class="pi-readonly-lbl">نوع</span>
                    <span class="pi-readonly-val">@Model.TypeDisplay</span>
                </div>
                <div class="pi-readonly-sep"></div>
                <div class="pi-readonly-item">
                    <span class="pi-readonly-lbl">نوع داده</span>
                    <span class="pi-readonly-val">@Model.DataTypeDisplay</span>
                </div>
            </div>

            @* ── ویژگی‌های قابل ویرایش ── *@
            <div class="pi-section-label">
                <span class="pi-section-num">۱</span>
                ویژگی‌های قابل تنظیم
            </div>

            <div class="pi-toggles-grid mb-8">
                <label class="pi-toggle-card" for="isInsured">
                    <div class="pi-toggle-icon pi-toggle-blue"><i class="fas fa-shield-alt"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">مشمول بیمه</span>
                        <span class="pi-toggle-desc">کسر حق بیمه</span>
                    </div>
                    <div class="pi-toggle-switch">
                        <input class="pi-toggle-input" type="checkbox" asp-for="IsInsured" id="isInsured" />
                        <span class="pi-toggle-slider"></span>
                    </div>
                </label>

                <label class="pi-toggle-card" for="isTaxable">
                    <div class="pi-toggle-icon pi-toggle-orange"><i class="fas fa-receipt"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">مشمول مالیات</span>
                        <span class="pi-toggle-desc">کسر مالیات</span>
                    </div>
                    <div class="pi-toggle-switch">
                        <input class="pi-toggle-input" type="checkbox" asp-for="IsTaxable" id="isTaxable" />
                        <span class="pi-toggle-slider"></span>
                    </div>
                </label>

                <label class="pi-toggle-card" for="isActive">
                    <div class="pi-toggle-icon pi-toggle-green"><i class="fas fa-power-off"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">فعال</span>
                        <span class="pi-toggle-desc">وضعیت نمایش در فیش</span>
                    </div>
                    <div class="pi-toggle-switch">
                        <input class="pi-toggle-input" type="checkbox" asp-for="IsActive" id="isActive" />
                        <span class="pi-toggle-slider"></span>
                    </div>
                </label>

                <div class="pi-toggle-card" style="cursor:default;">
                    <div class="pi-toggle-icon pi-toggle-purple"><i class="fas fa-sort-numeric-down"></i></div>
                    <div class="pi-toggle-info">
                        <span class="pi-toggle-title">ترتیب نمایش</span>
                        <span class="pi-toggle-desc">در لیست و فیش حقوقی</span>
                    </div>
                    <input type="number" asp-for="SortOrder"
                           class="pi-sortorder-input" min="0" />
                </div>
            </div>

            @* ── بخش فرمول (فقط اگر DataType == Formula) ── *@
            @if (Model.HasDataTypeFormula)
            {
                <div class="pi-section-label">
                    <span class="pi-section-num"><i class="fas fa-function" style="font-size:.6rem"></i></span>
                    فرمول محاسباتی
                </div>

                <div class="pi-formula-wrapper">

                    @* انتخاب حالت: پیش‌فرض یا سفارشی *@
                    <div class="pi-formula-mode-selector mb-5">
                        <label class="pi-mode-option @(Model.UseDefaultFormula ? "active" : "")">
                            <input type="radio" name="UseDefaultFormula" value="true"
                                   id="modeDefault" @(Model.UseDefaultFormula ? "checked" : "")
                                   onchange="setFormulaMode(true)" />
                            <i class="fas fa-magic me-2"></i>
                            استفاده از فرمول پیش‌فرض سیستم
                        </label>
                        <label class="pi-mode-option @(!Model.UseDefaultFormula ? "active" : "")">
                            <input type="radio" name="UseDefaultFormula" value="false"
                                   id="modeCustom" @(!Model.UseDefaultFormula ? "checked" : "")
                                   onchange="setFormulaMode(false)" />
                            <i class="fas fa-edit me-2"></i>
                            تعریف فرمول سفارشی
                        </label>
                    </div>

                    @* نمایش فرمول پیش‌فرض *@
                    <div id="defaultFormulaPanel" style="@(Model.UseDefaultFormula ? "" : "display:none")">
                        <div class="pi-default-formula-box">
                            <div class="pi-default-formula-label">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                فرمول پیش‌فرض فعال است:
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.DefaultFormula))
                            {
                                <code class="pi-default-formula-code" dir="ltr">
                                    @Model.DefaultFormula
                                </code>
                            }
                            else
                            {
                                <span class="text-muted fs-7">این عامل فرمول پیش‌فرضی ندارد</span>
                            }
                        </div>
                    </div>

                    @* ویرایشگر فرمول سفارشی *@
                    <div id="customFormulaPanel" style="@(!Model.UseDefaultFormula ? "" : "display:none")">

                        @if (!string.IsNullOrWhiteSpace(Model.DefaultFormula))
                        {
                            <div class="pi-info-box mb-4">
                                <i class="fas fa-info-circle me-2"></i>
                                فرمول پیش‌فرض سیستم:
                                <code dir="ltr" class="ms-2">@Model.DefaultFormula</code>
                                <button type="button" class="pi-copy-default-btn ms-3"
                                        onclick="copyDefaultFormula()">
                                    <i class="fas fa-copy me-1"></i>کپی در ویرایشگر
                                </button>
                            </div>
                        }

                        <div class="row g-5 mb-4">
                            <div class="col-md-8">
                                <label class="pi-label required">فرمول سفارشی</label>
                                <div class="pi-editor-wrap">
                                    <div class="pi-editor-bar">
                                        <span class="pi-editor-dot red"></span>
                                        <span class="pi-editor-dot yellow"></span>
                                        <span class="pi-editor-dot green"></span>
                                        <span class="pi-editor-lang">FORMULA</span>
                                    </div>
                                    <textarea asp-for="Formula" id="formulaInput"
                                              class="pi-editor-textarea"
                                              rows="3"
                                              placeholder="@Model.DefaultFormula"
                                              oninput="onFormulaChange()"></textarea>
                                </div>
                                <span asp-validation-for="Formula" class="pi-error-msg"></span>

                                <div id="formulaValidationResult" class="pi-status-bar" style="display:none;">
                                    <div id="formulaValidOk" class="pi-status pi-status-ok" style="display:none;">
                                        <i class="fas fa-check-circle"></i>
                                        <span id="formulaTestResult"></span>
                                    </div>
                                    <div id="formulaValidErr" class="pi-status pi-status-err" style="display:none;">
                                        <i class="fas fa-times-circle"></i>
                                        <span id="formulaErrorMsg"></span>
                                    </div>
                                    <div id="formulaValidWarn" class="pi-status pi-status-warn" style="display:none;">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        <span id="formulaWarnMsg"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="pi-label required">تاریخ شروع اعتبار</label>
                                <input type="date" asp-for="FormulaValidFromDate"
                                       class="pi-input text-center"
                                       value="@(Model.FormulaValidFromDate?.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" />
                                <span asp-validation-for="FormulaValidFromDate" class="pi-error-msg"></span>

                                @* دکمه بازگشت به پیش‌فرض *@
                                @if (!Model.UseDefaultFormula && !string.IsNullOrWhiteSpace(Model.DefaultFormula))
                                {
                                    <form asp-action="ResetSystemFormula" asp-controller="PayItem"
                                          asp-route-systemCode="@Model.SystemCode"
                                          method="post" class="mt-3">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="pi-reset-formula-btn w-100"
                                                onclick="return confirm('فرمول به حالت پیش‌فرض بازمی‌گردد. مطمئنید؟')">
                                            <i class="fas fa-undo me-1"></i>بازگشت به فرمول پیش‌فرض
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        @* انتخاب‌گر عوامل + پنل تست *@
                        <div class="pi-picker mt-2">
                            <div class="pi-picker-header">
                                <span class="pi-picker-title">
                                    <i class="fas fa-database me-2 text-muted"></i>
                                    انتخاب متغیر
                                </span>
                                <div class="pi-search-wrap">
                                    <i class="fas fa-search pi-search-icon"></i>
                                    <input type="text" id="codeSearch" class="pi-search-input"
                                           placeholder="جستجو..." oninput="filterCodes(this.value)" />
                                </div>
                            </div>
                            <div class="pi-tabs" id="codeGroupTabs">
                                <button type="button" class="pi-tab active" onclick="filterByGroup('all',this)">همه</button>
                                <button type="button" class="pi-tab pi-tab-info" onclick="filterByGroup('کارکرد',this)"><i class="fas fa-clock me-1"></i>کارکرد</button>
                                <button type="button" class="pi-tab pi-tab-success" onclick="filterByGroup('مزایا',this)"><i class="fas fa-plus me-1"></i>مزایا</button>
                                <button type="button" class="pi-tab pi-tab-danger" onclick="filterByGroup('کسورات',this)"><i class="fas fa-minus me-1"></i>کسورات</button>
                                <button type="button" class="pi-tab pi-tab-primary" onclick="filterByGroup('اطلاعاتی',this)"><i class="fas fa-info me-1"></i>اطلاعاتی</button>
                            </div>
                            <div id="codeGrid" class="pi-code-grid"></div>
                        </div>

                        <div id="formulaTestPanel" class="pi-test-panel mt-4" style="display:none;">
                            <div class="pi-test-header">
                                <i class="fas fa-vial me-2"></i>
                                تست فرمول با مقادیر دلخواه
                                <span class="pi-test-hint">مقادیر را وارد کنید و Enter بزنید</span>
                            </div>
                            <div id="formulaVarInputs" class="pi-var-grid"></div>
                            <div class="d-flex align-items-center gap-3 mt-3" style="padding: 0 16px 4px;">
                                <button type="button" class="pi-calc-btn" onclick="runFormulaTest()">
                                    <i class="fas fa-play me-2"></i>محاسبه
                                </button>
                                <button type="button" class="pi-reset-btn" onclick="resetTestInputs()">
                                    <i class="fas fa-redo me-1"></i>صفر کردن
                                </button>
                            </div>
                            <div id="formulaTestOutput" class="pi-test-output" style="display:none;"></div>
                        </div>

                    </div>
                </div>
            }

        </div>
    </div>
</form>

@section Scripts {
    <script>
        // ─── داده‌ها ───────────────────────────────────────────────────
        const ALL_CODES = @Html.Raw(allCodesJson);
        const DEFAULT_FORMULA = '@Html.Raw(Model.DefaultFormula?.Replace("'", "\\'") ?? "")';

        const GROUP_META = {
            'کارکرد':   { cls: 'grp-info',    icon: 'fa-clock'        },
            'مزایا':    { cls: 'grp-success',  icon: 'fa-plus-circle'  },
            'کسورات':   { cls: 'grp-danger',   icon: 'fa-minus-circle' },
            'اطلاعاتی': { cls: 'grp-primary',  icon: 'fa-info-circle'  },
            'سفارشی':   { cls: 'grp-warning',  icon: 'fa-star'         },
        };
        const VALID_CODES_SET = new Set(ALL_CODES.map(x => x.code.toUpperCase()));

        let activeGroup = 'all', searchText = '', debounceTimer = null;

        // ─── حالت فرمول ───────────────────────────────────────────────
        function setFormulaMode(useDefault) {
            document.getElementById('defaultFormulaPanel').style.display = useDefault ? 'block' : 'none';
            document.getElementById('customFormulaPanel').style.display  = useDefault ? 'none'  : 'block';
            document.querySelectorAll('.pi-mode-option').forEach(el => el.classList.remove('active'));
            document.getElementById(useDefault ? 'modeDefault' : 'modeCustom')
                .closest('.pi-mode-option').classList.add('active');
        }

        function copyDefaultFormula() {
            const ta = document.getElementById('formulaInput');
            ta.value = DEFAULT_FORMULA;
            ta.focus();
            onFormulaChange();
        }

        // ─── گرید عوامل ───────────────────────────────────────────────
        function renderCodeGrid() {
            const grid = document.getElementById('codeGrid');
            if (!grid) return;
            grid.innerHTML = '';
            const filtered = ALL_CODES.filter(item => {
                const matchGroup  = activeGroup === 'all' || item.group === activeGroup;
                const matchSearch = !searchText || item.name.includes(searchText) ||
                    item.code.toLowerCase().includes(searchText.toLowerCase());
                return matchGroup && matchSearch;
            });
            if (!filtered.length) {
                grid.innerHTML = '<div class="pi-empty"><i class="fas fa-search-minus"></i><span>موردی یافت نشد</span></div>';
                return;
            }
            filtered.forEach(item => {
                const meta = GROUP_META[item.group] || { cls: 'grp-secondary', icon: 'fa-tag' };
                const chip = document.createElement('div');
                chip.className = `pi-chip ${meta.cls}`;
                chip.title = 'کلیک برای درج';
                chip.innerHTML = `<i class="fas ${meta.icon} pi-chip-icon"></i>
                    <div class="pi-chip-body">
                        <span class="pi-chip-name">${item.name}</span>
                        <code class="pi-chip-code">${item.code}</code>
                    </div>`;
                chip.addEventListener('click', () => insertCodeAtCursor(item.code));
                grid.appendChild(chip);
            });
        }

        function filterByGroup(group, btn) {
            activeGroup = group;
            document.querySelectorAll('#codeGroupTabs .pi-tab').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            renderCodeGrid();
        }
        function filterCodes(val) { searchText = val; renderCodeGrid(); }

        function insertCodeAtCursor(code) {
            const ta = document.getElementById('formulaInput');
            if (!ta) return;
            const s = ta.selectionStart, e = ta.selectionEnd, v = ta.value;
            const before = (s > 0 && v[s-1] !== ' ') ? ' ' : '';
            const after  = (e < v.length && v[e] !== ' ') ? ' ' : '';
            ta.value = v.substring(0,s) + before + code + after + v.substring(e);
            ta.selectionStart = ta.selectionEnd = s + before.length + code.length + after.length;
            ta.focus();
            onFormulaChange();
        }

        // ─── ولیدیشن ─────────────────────────────────────────────────
        function extractVars(formula) {
            return [...new Set((formula.match(/\b([A-Z][A-Z0-9_]*)\b/g) || []).map(v => v.toUpperCase()))];
        }
        function escapeRegex(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

        function onFormulaChange() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(_doValidate, 350);
        }

        function _doValidate() {
            const ta = document.getElementById('formulaInput');
            if (!ta) return;
            const formula = ta.value.trim();
            const resultDiv = document.getElementById('formulaValidationResult');
            const testPanel = document.getElementById('formulaTestPanel');

            hideAll(); resultDiv.style.display = 'none'; testPanel.style.display = 'none';
            if (!formula) return;

            resultDiv.style.display = 'block';
            const vars = extractVars(formula);
            const invalid = vars.filter(v => !VALID_CODES_SET.has(v));

            if (!vars.length) { showWarn('فرمول باید حداقل یک متغیر داشته باشد'); return; }
            if (invalid.length) { showError(`کدهای ناشناخته: <strong>${invalid.join('، ')}</strong>`); return; }

            let test = formula;
            vars.forEach(v => { test = test.replace(new RegExp(`\\b${escapeRegex(v)}\\b`, 'gi'), '(1)'); });

            try {
                const r = new Function('"use strict"; return (' + test + ')')();
                if (typeof r !== 'number' || isNaN(r)) { showError('فرمول عددی برنمی‌گرداند'); return; }
                if (!isFinite(r)) showWarn('احتمال تقسیم بر صفر');
                else showOk('ساختار فرمول صحیح است');
                buildTestPanel(vars);
                testPanel.style.display = 'block';
            } catch(e) { showError(`خطای ساختاری: ${friendlyError(e.message)}`); }
        }

        function hideAll() {
            ['formulaValidOk','formulaValidErr','formulaValidWarn'].forEach(id => {
                const el = document.getElementById(id); if (el) el.style.display = 'none';
            });
        }
        function showOk(msg)   { const e=document.getElementById('formulaValidOk');  document.getElementById('formulaTestResult').textContent=msg; e.style.display='flex'; }
        function showError(msg){ const e=document.getElementById('formulaValidErr'); document.getElementById('formulaErrorMsg').innerHTML=msg;   e.style.display='flex'; }
        function showWarn(msg) { const e=document.getElementById('formulaValidWarn');document.getElementById('formulaWarnMsg').textContent=msg;  e.style.display='flex'; }
        function friendlyError(msg) {
            if (msg.includes('Unexpected token') || msg.includes('expected expression')) return 'عبارت ناقص';
            if (msg.includes('is not defined')) return 'متغیر تعریف‌نشده';
            return msg;
        }

        // ─── پنل تست ─────────────────────────────────────────────────
        function buildTestPanel(vars) {
            const container = document.getElementById('formulaVarInputs');
            const oldVals = {};
            container.querySelectorAll('.pi-var-input').forEach(inp => { oldVals[inp.dataset.var] = inp.value; });
            container.innerHTML = '';
            vars.forEach(v => {
                const info = ALL_CODES.find(x => x.code.toUpperCase() === v);
                const meta = info ? (GROUP_META[info.group] || {}) : {};
                const wrap = document.createElement('div');
                wrap.className = 'pi-var-item';
                wrap.innerHTML = `
                    <label class="pi-var-label"><i class="fas ${meta.icon||'fa-tag'} me-1 opacity-50"></i>${info?.name||v}</label>
                    <code class="pi-var-code">${v}</code>
                    <input type="number" class="pi-var-input" data-var="${v}"
                           value="${oldVals[v]??'0'}" step="any" placeholder="0"
                           onkeydown="if(event.key==='Enter'){event.preventDefault();runFormulaTest();}" />`;
                container.appendChild(wrap);
            });
        }

        function runFormulaTest() {
            const formula = document.getElementById('formulaInput')?.value.trim();
            const output = document.getElementById('formulaTestOutput');
            output.style.display = 'none';
            if (!formula) return;

            let test = formula;
            document.querySelectorAll('.pi-var-input').forEach(inp => {
                const val = parseFloat(inp.value);
                test = test.replace(new RegExp(`\\b${escapeRegex(inp.dataset.var)}\\b`, 'gi'), `(${isNaN(val)?0:val})`);
            });

            output.style.display = 'block';
            try {
                const r = new Function('"use strict"; return (' + test + ')')();
                if (!isFinite(r) || isNaN(r)) {
                    output.innerHTML = `<div class="pi-result pi-result-warn"><i class="fas fa-exclamation-triangle me-2"></i>تقسیم بر صفر</div>`;
                    return;
                }
                const expr = test.replace(/\((\d+(\.\d+)?)\)/g, '$1');
                output.innerHTML = `<div class="pi-result pi-result-ok">
                    <div class="pi-result-label">نتیجه</div>
                    <div class="pi-result-value">${r.toLocaleString('fa-IR',{maximumFractionDigits:4})}</div>
                    <div class="pi-result-expr" dir="ltr">${expr}</div></div>`;
            } catch(e) {
                output.innerHTML = `<div class="pi-result pi-result-err"><i class="fas fa-times-circle me-2"></i>${friendlyError(e.message)}</div>`;
            }
        }
        function resetTestInputs() {
            document.querySelectorAll('.pi-var-input').forEach(inp => inp.value = '0');
            document.getElementById('formulaTestOutput').style.display = 'none';
        }

        // ─── ولیدیشن submit ───────────────────────────────────────────
        document.getElementById('editSystemForm').addEventListener('submit', function(e) {
            const useDefault = document.getElementById('modeDefault')?.checked ?? true;
            if (useDefault) return; // پیش‌فرض → همیشه OK

            const formula = document.getElementById('formulaInput')?.value.trim();
            const errEl   = document.getElementById('formulaValidErr');

            if (!formula) {
                e.preventDefault();
                document.getElementById('formulaInput').classList.add('is-invalid');
                return;
            }
            if (errEl?.style.display !== 'none') {
                e.preventDefault();
                errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });

        // ─── init ────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function() {
            renderCodeGrid();
            const formula = document.getElementById('formulaInput')?.value;
            if (formula) onFormulaChange();
        });
    </script>
}

@section customStyles {
    <link href="~/css/firststepstyles.css" rel="stylesheet" asp-append-version="true" nonce="@Context.Items["ScriptNonce"]" />
    <style>
        /* ──── کارت ──── */
        .pi-card-main {
            border: 1px solid #e4e6ef;
            border-radius: 14px !important;
            box-shadow: 0 2px 20px rgba(0,0,0,.06) !important;
        }

        .pi-card-header {
            background: linear-gradient(135deg,#1e2a45 0%,#2d3f6e 100%) !important;
            border-radius: 14px 14px 0 0 !important;
