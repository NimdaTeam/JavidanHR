@using Microsoft.AspNetCore.Mvc.TagHelpers
@using PayrollSystem.Domain.Entities.Contract
@using WebHost.Helpers.GlobalHelpers
@model _0_Framework.Utilities.Pagination.PaginationResult<PayrollSystem.Application.DTOs.ContractDto>
@{
    ViewData["Title"] = "لیست قراردادها";
    int row = ((Model.CurrentPage - 1) * 50) + 1;

    // Calculate status counts
    int totalCount = Model.PaginatedList.Count;
    int activeCount = Model.PaginatedList.Count(c => c is { IsActive: true, Status: ContractStatus.Active });
    int inactiveCount = Model.PaginatedList.Count(c => !c.IsActive || c.Status == ContractStatus.Inactive);
    int terminatedCount = Model.PaginatedList.Count(c => c.Status == ContractStatus.Terminated);
}

@section customStyles {
    <style>
        /* Contract-specific styles with ct- prefix */
        .ct-card {
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            border: none;
            overflow: hidden;
        }

        .ct-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 2rem;
            color: white;
        }

        .ct-stats {
            display: flex;
            gap: 1.5rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }

        .ct-stat-item {
            background: rgba(255,255,255,0.15);
            padding: 0.75rem 1.25rem;
            border-radius: 12px;
            backdrop-filter: blur(10px);
        }

        .ct-stat-label {
            font-size: 0.85rem;
            opacity: 0.9;
            margin-bottom: 0.25rem;
        }

        .ct-stat-value {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .ct-table {
            margin: 0;
        }

            .ct-table thead th {
                background: #f8f9fa;
                border: none;
                padding: 1rem;
                font-weight: 600;
                color: #495057;
            }

            .ct-table tbody td {
                padding: 1rem;
                vertical-align: middle;
                border-top: 1px solid #e9ecef;
            }

            .ct-table tbody tr:hover {
                background: #f8f9fa;
            }

            .ct-table tbody tr.inactive-row {
                opacity: 0.5;
            }

        .ct-employee-info {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .ct-employee-name {
            font-weight: 600;
            color: #2c3e50;
        }

        .ct-workshop-name {
            font-size: 0.85rem;
            color: #6c757d;
        }

        .ct-date-range {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            font-size: 0.9rem;
        }

        .ct-date-label {
            color: #6c757d;
            font-size: 0.8rem;
        }

        .ct-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .ct-btn {
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            font-size: 0.85rem;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }

        .ct-btn-view {
            background: #e3f2fd;
            color: #1976d2;
        }

            .ct-btn-view:hover {
                background: #1976d2;
                color: white;
            }

        .ct-btn-edit {
            background: #fff3e0;
            color: #f57c00;
        }

            .ct-btn-edit:hover {
                background: #f57c00;
                color: white;
            }

        .ct-btn-delete {
            background: #ffebee;
            color: #c62828;
        }

            .ct-btn-delete:hover {
                background: #c62828;
                color: white;
            }

        .ct-filter-section {
            padding: 1.5rem;
            background: #f8f9fa;
            border-bottom: 1px solid #dee2e6;
        }

        .ct-filter-group {
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .ct-filter-btn {
            padding: 0.5rem 1rem;
            border-radius: 20px;
            border: 2px solid #dee2e6;
            background: white;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.9rem;
        }

            .ct-filter-btn.active {
                background: #667eea;
                color: white;
                border-color: #667eea;
            }

            .ct-filter-btn:hover {
                border-color: #667eea;
            }

        /* Responsive design */
        @@media (max-width: 768px) {
            .ct-header {
                padding: 1.5rem;
            }

            .ct-stats {
                gap: 1rem;
            }

            .ct-stat-item {
                flex: 1 1 calc(50% - 0.5rem);
                min-width: 120px;
            }

            .ct-table {
                font-size: 0.85rem;
            }

            .ct-actions {
                flex-direction: column;
            }

            .ct-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

<div class="container-fluid py-4">
    <div class="ct-card">
        <!-- Header with stats -->
        <div class="ct-header">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h4 class="mb-1">لیست قراردادها</h4>
                    <p class="mb-0 opacity-75">مدیریت قراردادهای کارکنان</p>
                </div>
                <a href="@Url.Action("AddContract", "Contract")" class="btn btn-light">
                    <i class="fas fa-plus ms-2"></i>
                    افزودن قرارداد جدید
                </a>
            </div>

            <div class="ct-stats">
                <div class="ct-stat-item">
                    <div class="ct-stat-label">مجموع</div>
                    <div class="ct-stat-value">@totalCount</div>
                </div>
                <div class="ct-stat-item">
                    <div class="ct-stat-label">فعال</div>
                    <div class="ct-stat-value">@activeCount</div>
                </div>
                <div class="ct-stat-item">
                    <div class="ct-stat-label">غیرفعال</div>
                    <div class="ct-stat-value">@inactiveCount</div>
                </div>
                <div class="ct-stat-item">
                    <div class="ct-stat-label">خاتمه یافته</div>
                    <div class="ct-stat-value">@terminatedCount</div>
                </div>
            </div>
        </div>

        <!-- Filter section -->
        <div class="ct-filter-section">
            <form method="get" id="filterForm">
                <div class="ct-filter-group">
                    <label class="mb-0 fw-bold">فیلتر وضعیت:</label>
                    <button type="button" class="ct-filter-btn @(string.IsNullOrEmpty(Context.Request.Query["status"]) ? "active" : "")"
                            onclick="filterByStatus('')">
                        همه
                    </button>
                    <button type="button" class="ct-filter-btn @(Context.Request.Query["status"] == "Active" ? "active" : "")"
                            onclick="filterByStatus('Active')">
                        فعال
                    </button>
                    <button type="button" class="ct-filter-btn @(Context.Request.Query["status"] == "Inactive" ? "active" : "")"
                            onclick="filterByStatus('Inactive')">
                        غیرفعال
                    </button>
                    <button type="button" class="ct-filter-btn @(Context.Request.Query["status"] == "Terminated" ? "active" : "")"
                            onclick="filterByStatus('Terminated')">
                        خاتمه یافته
                    </button>
                </div>
                <input type="hidden" name="status" id="statusInput" value="@Context.Request.Query["status"]" />
                <input type="hidden" name="page" value="1" />
            </form>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table ct-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>کارمند / کارگاه</th>
                        <th>تاریخ شروع</th>
                        <th>تاریخ پایان</th>
                        <th>تعداد آیتم‌ها</th>
                        <th>وضعیت</th>
                        <th style="width: 200px;">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.PaginatedList.Any())
                    {
                        @foreach (var contract in Model.PaginatedList)
                        {
                            <tr class="@(!contract.IsActive || contract.Status == ContractStatus.Terminated ? "inactive-row" : "")">
                                <td>@row</td>
                                <td>
                                    <div class="ct-employee-info">
                                        <span class="ct-employee-name">@contract.EmployeeName</span>
                                        <span class="ct-workshop-name">
                                            <i class="fas fa-building ms-1"></i>
                                            @contract.WorkshopName
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div class="ct-date-range">
                                        <span>@contract.ValidFromDate.ToString("yyyy/MM/dd")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="ct-date-range">
                                        @if (contract.ValidToDate.HasValue)
                                        {
                                            <span>@contract.ValidToDate.Value.ToString("yyyy/MM/dd")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">نامحدود</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-light-info">
                                        @contract.PayItems.Count آیتم
                                    </span>
                                </td>
                                <td>
                                    @if (contract.Status == ContractStatus.Active)
                                    {
                                        <span class="badge badge-light-success">فعال</span>
                                    }
                                    else if (contract.Status == ContractStatus.Inactive)
                                    {
                                        <span class="badge badge-light-warning">غیرفعال</span>
                                    }
                                    else if (contract.Status == ContractStatus.Terminated)
                                    {
                                        <span class="badge badge-light-danger">خاتمه یافته</span>
                                    }
                                </td>
                                <td>
                                    <div class="ct-actions">
                                        <a href="@Url.Action("EditContract", "Contract", new { id = contract.Id })"
                                           class="ct-btn ct-btn-edit" title="ویرایش">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        @if (contract.Status is not ContractStatus.Terminated and not ContractStatus.Active)
                                        {
                                            <button type="button" class="ct-btn ct-btn-delete"
                                                    onclick="confirmDelete('@contract.Id', '@contract.EmployeeName')"
                                                    title="حذف">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                            row++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                <p class="text-muted">هیچ قراردادی یافت نشد</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="p-3">
                <pagination page-model="@Model"></pagination>
            </div>
        }
    </div>
</div>

@section SearchBox {
    <searchBox search-query="@Model.SearchQuery"></searchBox>
}

@section Scripts {
    <script>
        // Filter by status
        function filterByStatus(status) {
            document.getElementById('statusInput').value = status;
            document.getElementById('filterForm').submit();
        }

        // Confirm delete
        function confirmDelete(contractId, employeeName) {
            if (confirm(`آیا از حذف قرارداد "${employeeName}" اطمینان دارید؟\n\nتوجه: این عملیات غیرقابل بازگشت است.`)) {
                // Create form and submit
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("DeleteContract", "Contract")';

                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'id';
                input.value = contractId;

                const token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (token) {
                    form.appendChild(token.cloneNode());
                }

                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
