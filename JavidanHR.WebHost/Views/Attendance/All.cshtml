@section SearchBox
{
    @* <searchBox search-query="@Model.SearchQuery"></searchBox> *@
}

@section Scripts {

    <Simple-CU-Modal add-route=""
                     update-route="">
    </Simple-CU-Modal>

    <script nonce="@Context.Items["ScriptNonce"]">
        $(document).ready(function () {
            // مقدار اولیه از query string
            const urlParams = new URLSearchParams(window.location.search);

            const selectedUser = urlParams.get('userFilter');
            const selectedDate = urlParams.get('persianDateString');

            $('#userFilter').select2({
                placeholder: "انتخاب کاربر",
                allowClear: true,
                width: 'resolve',
                dir: "rtl"
            });



            if (selectedUser) {
                $('#userFilter').val(selectedUser).trigger('change');
            }

            if (selectedDate) {
                $('#dateFilter').val(selectedDate).trigger('change');
            }


            // تابع برای بروزرسانی URL بر اساس هردو فیلتر
            function updateUrl() {
                const user = $('#userFilter').val();
                const date = $('#dateFilter').val();

                let baseUrl = '/attendance/All';
                let queryParams = [];

                 if (date) queryParams.push('persianDateString=' + date);
                if (user) queryParams.push('userFilter=' + user);
               

                if (queryParams.length > 0) {
                    baseUrl += '?' + queryParams.join('&');
                }

                window.location.href = baseUrl;
            }

            $('#userFilter').on('change', updateUrl);
            $('#dateFilter').on('change', updateUrl);
        });
    </script>

    
}