    var filteredUser = ViewBag.filteredUser;
    ViewData["Title"] = string.IsNullOrWhiteSpace(filteredDate) 
        ? "لیست آخرین تردد های ثبت شده" 
    : $"لیست تردد های ثبت شده در تاریخ «{filteredDate}»";

    if (!string.IsNullOrWhiteSpace(filteredUser))
    {
        ViewData["Title"] += $" برای کارمند «{filteredUser}»";
    }


    var cooperationTypeQuery = int.TryParse(Context.Request.Query["cooperationType"], out var ct) ? ct : (int?)null;

    var users = ViewBag.users as List<Employee>;
    var index = 1;
}

