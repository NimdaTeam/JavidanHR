@using _0_Framework.Utilities.Helpers
@using AuthenticationSystem.Domain.User
@using AuthenticationSystem.SystemPermissions
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using WebHost.Helpers.GlobalHelpers
@model IEnumerable<AttendanceSystem.Infrastructure.Dto.AttendanceLogItem>
@{
	var user = ViewBag.user as Users ?? new Users();
	ViewData["Title"] = $"لیست تردد های کارمند «{user.FullName}» در «{DateTime.Now.ToShamsi()}»";
	var maritalStatusQuery = int.TryParse(Context.Request.Query["maritalStatus"], out var ms) ? ms : (int?)null;
	var cooperationTypeQuery = int.TryParse(Context.Request.Query["cooperationType"], out var ct) ? ct : (int?)null;

	var index = 1;
}

<div class="card mb-5 mb-xl-8">
	<!--begin::Header-->
	<div class="card-header border-0 pt-5">
		<h3 class="card-title align-items-start flex-column">
			<span class="text-muted fw-semibold fs-6">تعداد کل تردد های امروز: @Model.Count()</span>
		</h3>
		<div class="card-toolbar d-flex flex-wrap gap-3">
			<!-- دکمه ایجاد کارمند جدید -->
			<div class="d-flex align-items-end">
				<a href="#" class="btn btn-lg btn-light-primary">
					<i class="ki-duotone ki-plus fs-2"></i> ثبت تردد جدید (در حال حاضر غیرفعال است)
				</a>
			</div>
		</div>
	</div>
	<!--end::Header-->
	<!--begin::Body-->
	<div class="card-body py-3">
		<div class="table-responsive">
			<table class="table table-bordered align-middle text-center table-hover">
				<thead>
					<tr class="fw-bold text-muted bg-light">
						<th style="max-width:20px !important">ردیف</th>
						<th>ساعت ورود</th>
						<th>ساعت خروج</th>
						<th>مدت زمان حضور</th>
						<th style="max-width:30px !important">وضعیت ثبت تردد</th>
						<th>عملیات</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var at in Model.OrderBy(x => x.SessionId))
					{
						var status = bool.Parse(at.IsIncomplete) ? "danger" : "success";
						var statusText = bool.Parse(at.IsIncomplete) ? "ناقص" : "کامل";
						<tr>
							<td class="fw-bold">@index</td>
							<td class="fw-bold">@at.InDateTime.ToShamsiWithoutDate()</td>
							<td class="fw-bold">
								@if (at.OutDateTime is null)
								{
									<span class="badge badge-light-danger fs-7 fw-semibold">تردد ثبت نشده</span>
									<a style="margin:2.5px" class="btn btn-icon btn-bg-light btn-active-color-warning btn-sm" href="#"
									   title="ثبت تردد خروج(در حال حاضر غیر فعال است)" data-bs-toggle="tooltip">
										<i class="fas fa-plus fs-2"></i>
									</a>
								}
								else
								{
									@at.OutDateTime.ToShamsiWithoutDate()
								}
							</td>
							<td class="fw-bold">@at.DurationMinutes.ToHourMinuteFormat()</td>
							<td class="fw-bold">  <span class="badge badge-light-@status fs-7 fw-semibold"> @statusText</span>  </td>
							<td>
								<a style="margin:2.5px" class="btn btn-icon btn-bg-light btn-active-color-warning btn-sm" href="#"
								   title="ویرایش تردد(در حال حاضر غیر فعال است)" data-bs-toggle="tooltip">
									<i class="fas fa-edit fs-2"></i>
								</a>

								@*<button style="margin:2.5px" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm delete-button"
										data-url="#" title="حذف تردد(در حال حاضر غیر فعال است)" data-bs-toggle="tooltip">
									<i class="fas fa-trash fs-2"></i>
								</button>*@
							</td>
						</tr>
						index++;
					}
				</tbody>
			</table>

			@*   <pagination page-model="@Model"></pagination> *@
		</div>
	</div>
</div>

@section SearchBox
{
	@* <searchBox search-query="@Model.SearchQuery"></searchBox> *@
}

@section Scripts {

	<Simple-CU-Modal add-route=""
					 update-route="">
	</Simple-CU-Modal>


	<script asp-append-version="true" nonce="@Context.Items["ScriptNonce"]">
		$(document).ready(function () {
			// فعال‌سازی Select2 برای تمام فیلترها
			$('#departmentFilter, #positionFilter, #maritalFilter, #coopFilter').select2({
				dir: 'rtl',
				language: 'fa',
				placeholder: 'انتخاب کنید',
				allowClear: true
			});

			// بروزرسانی URL با فیلترها
			function applyFilters() {
				const params = new URLSearchParams();
				const dept = $('#departmentFilter').val();
				const pos = $('#positionFilter').val();
				const marital = $('#maritalFilter').val();
				const coop = $('#coopFilter').val();

				if (dept) params.append('department', dept);
				if (pos) params.append('position', pos);
				if (marital) params.append('maritalStatus', marital);
				if (coop) params.append('cooperationType', coop);

				const base = window.location.pathname;
				window.location = params.toString() ? `${base}?${params}` : base;
			}

			$('#departmentFilter, #positionFilter, #maritalFilter, #coopFilter').on('change', applyFilters);
		});
	</script>
}