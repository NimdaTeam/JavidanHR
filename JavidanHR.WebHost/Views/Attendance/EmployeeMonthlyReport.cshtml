@using _0_Framework.Utilities.Helpers
@using AttendanceSystem.Infrastructure.Dto
@using AuthenticationSystem.Domain.User
@using DNTPersianUtils.Core
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using WebHost.Helpers.GlobalHelpers
@model List<AttendanceRecord>
@{
	var currentUser = ViewBag.currentUser as Users;
	var filteredYear = !string.IsNullOrWhiteSpace(Context.Request.Query["year"].ToString()) ? Context.Request.Query["year"] : ViewBag.filteredYear;
	var filteredMonth = !string.IsNullOrWhiteSpace(Context.Request.Query["month"].ToString()) ? Context.Request.Query["month"] : ViewBag.filteredMonth;
	var filteredUser = ViewBag.filteredUser as Users;
	ViewData["Title"] = $"وضعیت حضور و غیاب در ماه «{filteredYear}/{filteredMonth}»";
	if (filteredUser is not null) ViewData["Title"] += $" برای کارمند «{filteredUser.FullName}»";

	var months = ViewBag.months as List<DateEntity>;
	var years = ViewBag.years as List<DateEntity>;
	var selectedYear = ViewBag.currentYear as int?;
	var selectedMonth = ViewBag.currentMonth as int?;
	var calendar = ViewBag.calendar as List<PersianDay?> ?? [];
	var attendanceDict = Model?.ToDictionary(x => x.WorkDate ?? "") ?? new Dictionary<string, AttendanceRecord>();

	// محاسبه اولین روز ماه برای offset تقویم
	var firstDay = calendar.FirstOrDefault(d => d != null);
	int calendarOffset = 0;
	if (firstDay != null)
	{
		var firstGregorian = $"{firstDay.Year}/{firstDay.Month}/{firstDay.Day}".ToGregorian();
		if (firstGregorian.HasValue)
		{
			// تبدیل روز هفته به ایندکس ایرانی (شنبه=0 ... جمعه=6)
			calendarOffset = (int)firstGregorian.Value.DayOfWeek switch
			{
				6 => 0, // شنبه
				0 => 1, // یکشنبه
				1 => 2, // دوشنبه
				2 => 3, // سه‌شنبه
				3 => 4, // چهارشنبه
				4 => 5, // پنج‌شنبه
				5 => 6, // جمعه
				_ => 0
			};
		}
	}

	var totalPresent = Model?.Sum(x => x.TotalPresentMins) ?? 0;
	var totalOt = Model?.Sum(x => x.ApprovedOtMins) ?? 0;
	var totalDeficit = Model?.Sum(x => x.DeficitMins) ?? 0;
	var presentDays = Model?.Count(x => x.Status == "Present") ?? 0;
	var absentDays = Model?.Count(x => x.Status == "Absent") ?? 0;
	var lateDays = Model?.Count(x => x.Status == "Late") ?? 0;
	var leaveDays = Model?.Count(x => x.Status == "OnLeave") ?? 0;
}

<style>
	/* ═══════════════ تقویم حضور و غیاب ═══════════════ */
	:root {
		--att-present:   #16a34a;
		--att-absent:    #dc2626;
		--att-late:      #d97706;
		--att-leave:     #0891b2;
		--att-holiday:   #7c3aed;
		--att-incomplete:#ea580c;
		--att-empty:     #f1f5f9;
		--att-radius:    14px;
	}

	.att-page-wrapper {
		direction: rtl;
		font-family: 'Vazirmatn', 'IRANSans', Tahoma, sans-serif;
	}

	/* ─── کارت‌های خلاصه ─── */
	.att-summary-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
		gap: 14px;
		margin-bottom: 28px;
	}
	.att-summary-card {
		background: #fff;
		border-radius: var(--att-radius);
		padding: 18px 16px 14px;
		border: 1px solid #e2e8f0;
		display: flex;
		flex-direction: column;
		gap: 6px;
		transition: transform .18s, box-shadow .18s;
	}
	.att-summary-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.09); }
	.att-summary-card .icon {
		width: 36px; height: 36px; border-radius: 10px;
		display: flex; align-items: center; justify-content: center;
		font-size: 17px; margin-bottom: 2px;
	}
	.att-summary-card .label { font-size: 12px; color: #64748b; }
	.att-summary-card .value { font-size: 21px; font-weight: 700; color: #1e293b; }
	.att-summary-card .sub   { font-size: 11px; color: #94a3b8; }

	.icon-present  { background: #dcfce7; color: #16a34a; }
	.icon-absent   { background: #fee2e2; color: #dc2626; }
	.icon-late     { background: #fef3c7; color: #d97706; }
	.icon-leave    { background: #cffafe; color: #0891b2; }
	.icon-hours    { background: #ede9fe; color: #7c3aed; }
	.icon-ot       { background: #d1fae5; color: #059669; }
	.icon-deficit  { background: #fee2e2; color: #dc2626; }

	/* ─── فیلتر ─── */
	.att-filter-bar {
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: var(--att-radius);
		padding: 14px 20px;
		display: flex;
		align-items: center;
		gap: 14px;
		flex-wrap: wrap;
		margin-bottom: 22px;
	}
	.att-filter-bar label { font-size: 13px; color: #475569; font-weight: 600; white-space: nowrap; }

	/* ─── تقویم ─── */
	.att-calendar-wrap {
		background: #fff;
		border-radius: var(--att-radius);
		border: 1px solid #e2e8f0;
		overflow: hidden;
	}
	.att-calendar-header {
		background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
		padding: 18px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.att-calendar-header h2 {
		color: #fff;
		font-size: 17px;
		font-weight: 700;
		margin: 0;
	}
	.att-calendar-header .total-badge {
		background: rgba(255,255,255,.15);
		color: #fff;
		border-radius: 20px;
		padding: 5px 14px;
		font-size: 13px;
		font-weight: 600;
	}

	/* ─── سربرگ روزهای هفته ─── */
	.att-weekdays {
		display: grid;
		grid-template-columns: repeat(7, 1fr);
		border-bottom: 1px solid #f1f5f9;
	}
	.att-weekday {
		text-align: center;
		padding: 12px 4px;
		font-size: 12px;
		font-weight: 700;
		color: #64748b;
		letter-spacing: .02em;
	}
	.att-weekday.friday { color: #dc2626; }

	/* ─── شبکه روزها ─── */
	.att-grid {
		display: grid;
		grid-template-columns: repeat(7, 1fr);
		gap: 1px;
		background: #f1f5f9;
		padding: 1px;
	}

	/* ─── سلول روز ─── */
	.att-day {
		background: #fff;
		min-height: 110px;
		padding: 10px 10px 8px;
		display: flex;
		flex-direction: column;
		gap: 5px;
		cursor: pointer;
		transition: background .15s;
		position: relative;
	}
	.att-day:hover { background: #f8fafc; }
	.att-day.empty { background: #fafafa; cursor: default; min-height: 110px; }
	.att-day.holiday { background: #fff5f5; }
	.att-day.holiday:hover { background: #fee2e2; }

	.att-day-num {
		font-size: 18px;
		font-weight: 700;
		color: #1e293b;
		line-height: 1;
	}
	.att-day.holiday .att-day-num { color: #dc2626; }
	.att-day.friday-col .att-day-num { color: #dc2626; }

	.att-day-name {
		font-size: 10px;
		color: #94a3b8;
		margin-top: 1px;
	}

	/* ─── بادج وضعیت ─── */
	.att-status-pill {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 3px 9px;
		border-radius: 20px;
		font-size: 10.5px;
		font-weight: 600;
		width: fit-content;
		max-width: 100%;
	}
	.pill-present   { background:#dcfce7; color:#15803d; }
	.pill-absent    { background:#fee2e2; color:#b91c1c; }
	.pill-late      { background:#fef3c7; color:#b45309; }
	.pill-leave     { background:#cffafe; color:#0e7490; }
	.pill-holiday   { background:#f3e8ff; color:#7c3aed; }
	.pill-incomplete{ background:#ffedd5; color:#c2410c; }
	.pill-empty     { background:#f1f5f9; color:#94a3b8; }

	/* ─── ساعات کار ─── */
	.att-hours {
		font-size: 12px;
		font-weight: 600;
		color: #475569;
		margin-top: auto;
	}
	.att-hours span { color: #16a34a; }

	/* ─── ضربدر ناقص ─── */
	.att-incomplete-dot {
		position: absolute;
		top: 8px;
		left: 8px;
		width: 8px; height: 8px;
		border-radius: 50%;
		background: #ea580c;
		animation: blink 1.4s ease-in-out infinite;
	}
	@@keyframes blink {
		0%,100% { opacity:1; } 50% { opacity:.3; }
	}

	/* ─── نمای تعطیلی ─── */
	.att-holiday-name {
		font-size: 10px;
		color: #dc2626;
		line-height: 1.3;
	}

	/* ─── راهنمای رنگ ─── */
	.att-legend {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		padding: 14px 20px;
		border-top: 1px solid #f1f5f9;
		background: #fafafa;
	}
	.att-legend-item {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		color: #475569;
	}
	.att-legend-dot {
		width: 12px; height: 12px;
		border-radius: 3px;
		flex-shrink: 0;
	}

	/* ─── ریسپانسیو ─── */
	@@media (max-width: 768px) {
		.att-day { min-height: 72px; padding: 7px 6px; }
		.att-day-num { font-size: 14px; }
		.att-summary-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@@media (max-width: 480px) {
		.att-day { min-height: 56px; padding: 5px 4px; }
		.att-status-pill { display: none; }
	}
</style>

<input type="hidden" id="userFilter" value="@filteredUser?.Id" />

<div class="att-page-wrapper">

	<!-- ═══ فیلتر ═══ -->
	<div class="att-filter-bar">
		<label>فیلتر تاریخ</label>
		<select id="monthFilter" class="form-select form-select-solid text-center" style="width:150px;height:41px !important">
			<option value="">انتخاب ماه</option>
			@foreach (var m in months!)
			{
				if (selectedMonth is not null && int.Parse(m.EntityValue) == selectedMonth.Value)
				{
					<option selected="" value="@m.EntityValue">@m.EntityTitle</option>
				}
				else
				{
					<option value="@m.EntityValue">@m.EntityTitle</option>
				}
			}
		</select>
		/
		<select id="yearFilter" class="form-select form-select-solid text-center" style="width:150px;height:41px !important">
			<option value="">انتخاب سال</option>
			@foreach (var y in years!)
			{
				if (selectedYear is not null && int.Parse(y.EntityValue) == selectedYear.Value)
				{
					<option selected="" value="@y.EntityValue">@y.EntityTitle</option>
				}
				else
				{
					<option value="@y.EntityValue">@y.EntityTitle</option>
				}
			}
		</select>
		<button id="applyFilters" class="btn btn-dark btn-sm px-4" title="اعمال فیلترها">
			<i class="fas fa-check me-1"></i> اعمال
		</button>
	</div>

	<!-- ═══ کارت‌های خلاصه ═══ -->
	<div class="att-summary-grid">
		<div class="att-summary-card">
			<div class="icon icon-hours"><i class="bi bi-clock"></i></div>
			<span class="label">مجموع حضور</span>
			<span class="value">@totalPresent.ToHourMinuteFormat()</span>
			<span class="sub">کل ساعات کاری</span>
		</div>
		<div class="att-summary-card">
			<div class="icon icon-present"><i class="bi bi-check-circle"></i></div>
			<span class="label">روزهای حاضر</span>
			<span class="value">@presentDays</span>
			<span class="sub">روز حضور کامل</span>
		</div>
		<div class="att-summary-card">
			<div class="icon icon-absent"><i class="bi bi-x-circle"></i></div>
			<span class="label">روزهای غیبت</span>
			<span class="value">@absentDays</span>
			<span class="sub">روز غایب</span>
		</div>
		<div class="att-summary-card">
			<div class="icon icon-late"><i class="bi bi-exclamation-circle"></i></div>
			<span class="label">تأخیر</span>
			<span class="value">@lateDays</span>
			<span class="sub">روز با تأخیر</span>
		</div>
		<div class="att-summary-card">
			<div class="icon icon-leave"><i class="bi bi-calendar3"></i></div>
			<span class="label">مرخصی</span>
			<span class="value">@leaveDays</span>
			<span class="sub">روز مرخصی</span>
		</div>
		<div class="att-summary-card">
			<div class="icon icon-ot"><i class="bi bi-hourglass-top"></i></div>
			<span class="label">اضافه‌کاری</span>
			<span class="value">@totalOt.ToHourMinuteFormat()</span>
			<span class="sub">تأیید شده</span>
		</div>
		<div class="att-summary-card">
			<div class="icon icon-deficit"><i class="bi bi-dash-circle"></i></div>
			<span class="label">کسری کار</span>
			<span class="value">@totalDeficit.ToHourMinuteFormat()</span>
			<span class="sub">جمع کسری</span>
		</div>
	</div>

	<!-- ═══ تقویم ═══ -->
	<div class="att-calendar-wrap">
		<!-- سربرگ تقویم -->
		<div class="att-calendar-header">
			<h2><i class="bi bi-calendar3 me-2"></i>تقویم حضور و غیاب — @filteredYear/@filteredMonth</h2>
			<span class="total-badge">@Model?.Count تردد ثبت شده</span>
		</div>

		<!-- روزهای هفته -->
		<div class="att-weekdays">
			<div class="att-weekday">شنبه</div>
			<div class="att-weekday">یکشنبه</div>
			<div class="att-weekday">دوشنبه</div>
			<div class="att-weekday">سه‌شنبه</div>
			<div class="att-weekday">چهارشنبه</div>
			<div class="att-weekday">پنج‌شنبه</div>
			<div class="att-weekday friday">جمعه</div>
		</div>

		<!-- شبکه روزها -->
		<div class="att-grid">

			<!-- سلول‌های خالی برای offset -->
			@for (int e = 0; e < calendarOffset; e++)
			{
				<div class="att-day empty"></div>
			}

			<!-- روزها -->
			@foreach (var at in calendar)
			{
				if (at is null) continue;

				var persianDate = $"{at.Year}/{at.Month}/{at.Day}";
				var gregorianDate = persianDate.ToGregorian();
				var gregStr = gregorianDate?.ToString("yyyy-MM-dd") ?? "";
				var foundItem = attendanceDict.ContainsKey(gregStr) ? attendanceDict[gregStr] : null;

				var hasEnter = foundItem != null && !string.IsNullOrWhiteSpace(foundItem.FirstEnter) && foundItem.FirstEnter != "-" && foundItem.FirstEnter != "---";
				var hasExit = foundItem != null && !string.IsNullOrWhiteSpace(foundItem.LastExit) && foundItem.LastExit != "-" && foundItem.LastExit != "---";
				var isIncomplete = foundItem != null && (hasEnter != hasExit);
				var isHoliday = (at.Holidays != null && at.Holidays.Any()) || foundItem?.Status == "Holiday";

				// محاسبه ستون جمعه (ستون 7ام = index 6)
				var gregDow = gregorianDate?.DayOfWeek;
				var isFriday = gregDow == DayOfWeek.Friday;

				var dayClass = "att-day";
				if (isHoliday) dayClass += " holiday";
				if (isFriday) dayClass += " friday-col";

				string pillClass, pillText = null;
				if (isHoliday) { pillClass = "pill-holiday"; pillText = "تعطیل"; }
				else if (isIncomplete) { pillClass = "pill-incomplete"; pillText = "ناقص"; }
				else if (foundItem == null) { pillClass = "pill-empty"; pillText = "—"; }
				else pillClass = foundItem.Status switch
				{
					"Present" => "pill-present",
					"Absent" => "pill-absent",
					"Late" => "pill-late",
					"OnLeave" => "pill-leave",
					_ => "pill-empty"
				};
				if (!isHoliday && !isIncomplete && foundItem != null)
					pillText = foundItem.Status switch
					{
						"Present" => "حاضر",
						"Absent" => "غایب",
						"Late" => "با تأخیر",
						"OnLeave" => "مرخصی",
						_ => "—"
					};

				var onclickAttr = "";
				if (foundItem != null)
				{
					onclickAttr = $"showAttendanceDetail('{foundItem.PersonalCode}','{foundItem.WorkDate}','{gregorianDate.ToShamsi()}','{foundItem.FullName}','{foundItem.GroupName}','{foundItem.ShiftStart}','{foundItem.ShiftEnd}','{foundItem.FirstEnter}','{foundItem.LastExit}',{foundItem.TotalPresentMins},{foundItem.DelayMins},{foundItem.EarlyExitMins},{foundItem.DeficitMins},{foundItem.ApprovedOtMins},0,'{foundItem.Status}')";
				}
				else if (gregorianDate <= DateTime.Now && !isHoliday)
				{
					onclickAttr = $"window.location='/Attendance/EditDateAttendanceRecords/{currentUser?.Id}?workDate={gregStr}'";
				}

				<div class="@dayClass" @(onclickAttr != "" ? $"onclick=\"{onclickAttr}\"" : "") title="@persianDate">

					@if (isIncomplete)
					{
						<div class="att-incomplete-dot"></div>
					}

					<div class="att-day-num">@at.Day</div>
					<div class="att-day-name">@gregorianDate.GetPersianWeekDayName()</div>

					@if (isHoliday && at.Holidays != null)
					{
						<div class="att-holiday-name">
							@foreach (var h in at.Holidays)
							{
								if (h != "روز جمعه")
								{
									@h
									<br />
			 }
							}
						</div>
					}

					<span class="att-status-pill @pillClass">@pillText</span>

					@if (foundItem != null && foundItem.TotalPresentMins > 0)
					{
						<div class="att-hours">
							<span>@foundItem.TotalPresentMins.ToHourMinuteFormat()</span>
						</div>
					}

					@if (foundItem != null && gregorianDate <= DateTime.Now && !isHoliday)
					{
						<a href="/Attendance/EditDateAttendanceRecords/@currentUser?.Id?workDate=@gregStr"
						   class="att-edit-link"
						   onclick="event.stopPropagation()"
						   title="ویرایش تردد"
						   style="position:absolute;bottom:6px;left:6px;font-size:11px;color:#94a3b8;text-decoration:none;">
							<i class="fas fa-edit"></i>
						</a>
					}
				</div>
			}
		</div>

		<!-- راهنمای رنگ -->
		<div class="att-legend">
			<div class="att-legend-item"><div class="att-legend-dot" style="background:#dcfce7;border:1px solid #16a34a"></div> حاضر</div>
			<div class="att-legend-item"><div class="att-legend-dot" style="background:#fee2e2;border:1px solid #dc2626"></div> غایب</div>
			<div class="att-legend-item"><div class="att-legend-dot" style="background:#fef3c7;border:1px solid #d97706"></div> با تأخیر</div>
			<div class="att-legend-item"><div class="att-legend-dot" style="background:#cffafe;border:1px solid #0891b2"></div> مرخصی</div>
			<div class="att-legend-item"><div class="att-legend-dot" style="background:#f3e8ff;border:1px solid #7c3aed"></div> تعطیل</div>
			<div class="att-legend-item"><div class="att-legend-dot" style="background:#ffedd5;border:1px solid #ea580c"></div> تردد ناقص</div>
		</div>
	</div>
</div>

<!-- ═══ مودال جزئیات (بدون تغییر) ═══ -->
<div class="modal fade" id="attendanceDetailModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
	<div class="modal-dialog modal-dialog-centered modal-xl">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">
					<i class="bi bi-calendar-check me-2"></i>جزئیات حضور و غیاب
				</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div id="detailSpinner" class="text-center py-5 d-none">
					<div class="spinner-border text-primary" role="status">
						<span class="visually-hidden">در حال بارگذاری...</span>
					</div>
					<p class="mt-3 text-muted">در حال دریافت اطلاعات...</p>
				</div>
				<div id="detailContent">
					<div class="row">
						<div class="col-md-6 mb-4">
							<div class="card card-flush h-md-100 border">
								<div class="card-header bg-light">
									<h6 class="card-title mb-0"><i class="bi bi-person me-2"></i>اطلاعات کارمند</h6>
								</div>
								<div class="card-body pt-3">
									<div class="d-flex flex-column gap-2">
										<div class="d-flex justify-content-between"><span class="text-muted">نام:</span><span class="fw-bold" id="modalFullName">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">گروه:</span><span class="fw-bold" id="modalGroupName">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">تاریخ:</span><span class="fw-bold" id="modalWorkDate">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">وضعیت:</span><span class="badge badge-success" id="modalStatus">-</span></div>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-6 mb-4">
							<div class="card card-flush h-md-100 border">
