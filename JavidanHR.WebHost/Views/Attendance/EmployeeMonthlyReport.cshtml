		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title"><i class="bi bi-calendar-check me-2"></i>جزئیات حضور و غیاب</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div id="detailSpinner" class="text-center py-5 d-none">
					<div class="spinner-border text-primary" role="status"><span class="visually-hidden">در حال بارگذاری...</span></div>
					<p class="mt-3 text-muted">در حال دریافت اطلاعات...</p>
				</div>
				<div id="detailContent">
					<div class="row">
						<div class="col-md-6 mb-4">
							<div class="card card-flush h-md-100 border">
								<div class="card-header bg-light"><h6 class="card-title mb-0"><i class="bi bi-person me-2"></i>اطلاعات کارمند</h6></div>
								<div class="card-body pt-3">
									<div class="d-flex flex-column gap-2">
										<div class="d-flex justify-content-between"><span class="text-muted">نام:</span><span class="fw-bold" id="modalFullName">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">گروه:</span><span class="fw-bold" id="modalGroupName">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">تاریخ:</span><span class="fw-bold" id="modalWorkDate">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">وضعیت:</span><span class="badge" id="modalStatus">-</span></div>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-6 mb-4">
							<div class="card card-flush h-md-100 border">
								<div class="card-header bg-light"><h6 class="card-title mb-0"><i class="bi bi-clock me-2"></i>زمان‌بندی شیفت</h6></div>
								<div class="card-body pt-3">
									<div class="d-flex flex-column gap-2">
										<div class="d-flex justify-content-between"><span class="text-muted">شروع شیفت:</span><span class="fw-bold" id="modalShiftStart">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">پایان شیفت:</span><span class="fw-bold" id="modalShiftEnd">-</span></div>
										<hr class="my-2">
										<div class="d-flex justify-content-between"><span class="text-muted">اولین ورود:</span><span class="fw-bold text-primary" id="modalFirstEnter">-</span></div>
										<div class="d-flex justify-content-between"><span class="text-muted">آخرین خروج:</span><span class="fw-bold text-danger" id="modalLastExit">-</span></div>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="row">
						<div class="col-12">
							<div class="card card-flush border">
								<div class="card-header bg-light"><h6 class="card-title mb-0"><i class="bi bi-graph-up me-2"></i>آمار و گزارش</h6></div>
								<div class="card-body pt-3">
									<div class="row">
										<div class="col-6 col-md-3 mb-3"><div class="d-flex align-items-center bg-light-success rounded p-3"><div class="me-3"><i class="bi bi-check-circle fs-2 text-success"></i></div><div><div class="fs-7">مجموع حضور</div><div class="fs-5 fw-bold" id="modalTotalPresent">-</div></div></div></div>
										<div class="col-6 col-md-3 mb-3"><div class="d-flex align-items-center bg-light-warning rounded p-3"><div class="me-3"><i class="bi bi-exclamation-triangle fs-2 text-warning"></i></div><div><div class="fs-7">تأخیر</div><div class="fs-5 fw-bold" id="modalDelay">-</div></div></div></div>
										<div class="col-6 col-md-3 mb-3"><div class="d-flex align-items-center bg-light-danger rounded p-3"><div class="me-3"><i class="bi bi-arrow-left-circle fs-2 text-danger"></i></div><div><div class="fs-7">خروج زودتر</div><div class="fs-5 fw-bold" id="modalEarlyExit">-</div></div></div></div>
										<div class="col-6 col-md-3 mb-3"><div class="d-flex align-items-center bg-light-dark rounded p-3"><div class="me-3"><i class="bi bi-calculator fs-2 text-dark"></i></div><div><div class="fs-7 text-muted">کسری کار</div><div class="fs-5 fw-bold" id="modalTotalDeficit">-</div></div></div></div>
									</div>
									<div class="row mt-1">
										<div class="col-6 mb-3"><div class="d-flex align-items-center bg-light-success rounded p-3"><div class="me-3"><i class="bi bi-hourglass-top fs-2 text-success"></i></div><div><div class="fs-7">اضافه‌کاری تأیید شده</div><div class="fs-5 fw-bold" id="modalApprovedOT">-</div></div></div></div>
										<div class="col-6 mb-3"><div class="d-flex align-items-center bg-light-warning rounded p-3"><div class="me-3"><i class="bi bi-hourglass-split fs-2 text-warning"></i></div><div><div class="fs-7">در انتظار تأیید</div><div class="fs-5 fw-bold" id="modalPendingOT">-</div></div></div></div>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="row mt-3" id="trafficSection">
						<div class="col-12">
							<div class="card card-flush border">
								<div class="card-header bg-light"><h6 class="card-title mb-0"><i class="bi bi-list-ul me-2"></i>لیست ترددها</h6></div>
								<div class="card-body pt-0">
									<div class="table-responsive">
										<table class="table table-bordered table-striped table-hover align-middle">
											<thead class="bg-light">
											<tr>
												<th class="text-center">#</th>
												<th class="text-center">ورود</th>
												<th class="text-center">نوع ورود</th>
												<th class="text-center">خروج</th>
												<th class="text-center">نوع خروج</th>
												<th class="text-center">مدت</th>
											</tr>
											</thead>
											<tbody id="trafficTableBody"></tbody>
										</table>
									</div>
									<div id="noTrafficMessage" class="text-center text-muted py-3 d-none">
										<i class="bi bi-info-circle me-1"></i>ترددی یافت نشد
									</div>
								</div>
							</div>
						</div>
					</div>
					<hr/>
					<div style="display:flex;flex-direction:column;align-items:center;align-content:center;justify-content:center">
						<a id="editRecordsModalBtn"
						   class="btn btn-primary"
						   onclick="event.stopPropagation()"
						   target="_blank"
						   title="ویرایش تردد های این روز">
							<i class="fas fa-edit"></i> ویرایش تردد های این روز
						</a>
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
			</div>
		</div>
	</div>
</div>

@section SearchBox { }
	@section Scripts {
		<Simple-CU-Modal add-route="" update-route=""></Simple-CU-Modal>
		<script nonce="@Context.Items["ScriptNonce"]">
			$(document).ready(function () {
				const p = new URLSearchParams(window.location.search);
				$('#monthFilter').select2({ placeholder:"انتخاب ماه", allowClear:true, width:'resolve', dir:"rtl" });
				$('#yearFilter').select2({ placeholder:"انتخاب سال",  allowClear:true, width:'resolve', dir:"rtl" });
				if (p.get('year'))  $('#yearFilter').val(p.get('year')).trigger('change');
				if (p.get('month')) $('#monthFilter').val(p.get('month')).trigger('change');
				$('#applyFilters').on('click', function () {
					const user=$('#userFilter').val(), month=$('#monthFilter').val(), year=$('#yearFilter').val();
					let base='/attendance/EmployeeMonthlyReport', params=[];
					if (user)  params.push('userFilter='+user);
					if (year)  params.push('year='+year);
					if (month) params.push('month='+month);
					window.location.href = base + (params.length ? '?'+params.join('&') : '');
				});
			});
		</script>
		<script nonce="@Context.Items["ScriptNonce"]">
			function toHM(mins) {
				if (!mins||mins===0) return '0:00';
				return Math.floor(mins/60)+':'+String(mins%60).padStart(2,'0');
			}
			function fmtTime(s) {
				if (!s) return '-';
				try { return new Date(s).toLocaleTimeString('fa-IR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); }
				catch { return s; }
			}
			function showDetail(userId,personalCode,workDate,jalaliDate,fullName,groupName,
								shiftStart,shiftEnd,firstEnter,lastExit,
								totalPresent,delay,earlyExit,totalDeficit,approvedOT,pendingOT,status,workDateGreg) {

				new bootstrap.Modal(document.getElementById('attendanceDetailModal')).show();

				const editLink = document.getElementById('editRecordsModalBtn');

				document.getElementById('detailSpinner').classList.remove('d-none');
				document.getElementById('detailContent').classList.add('d-none');
				document.getElementById('modalFullName').textContent  = fullName  ||'-';
				document.getElementById('modalGroupName').textContent = groupName ||'-';
				document.getElementById('modalWorkDate').textContent  = jalaliDate||'-';

				if (userId && workDate) {
							editLink.href = `/Attendance/EditDateAttendanceRecords/${userId}?workDate=${workDateGreg}`;
				} else {
							editLink.href = '#';
			    }

				const sm={'Present':{t:'حاضر',c:'badge-success'},'Absent':{t:'غایب',c:'badge-danger'},
						   'Late':{t:'با تأخیر',c:'badge-warning'},'OnLeave':{t:'مرخصی',c:'badge-info'},
						   'Holiday':{t:'تعطیل',c:'badge-danger'}};
				const si=sm[status]||{t:status||'-',c:'badge-secondary'};
				const se=document.getElementById('modalStatus');
				se.textContent=si.t; se.className='badge '+si.c;
				document.getElementById('modalShiftStart').textContent   = shiftStart  ||'-';
				document.getElementById('modalShiftEnd').textContent     = shiftEnd    ||'-';
				document.getElementById('modalFirstEnter').textContent   = firstEnter  ||'-';
				document.getElementById('modalLastExit').textContent     = lastExit    ||'-';
				document.getElementById('modalTotalPresent').textContent = toHM(totalPresent);
				document.getElementById('modalDelay').textContent        = toHM(delay);
				document.getElementById('modalEarlyExit').textContent    = toHM(earlyExit);
				document.getElementById('modalTotalDeficit').textContent = toHM(totalDeficit);
				document.getElementById('modalApprovedOT').textContent   = toHM(approvedOT);
				document.getElementById('modalPendingOT').textContent    = toHM(pendingOT);
				$.ajax({
					url:'/Attendance/GetDailyAttendanceDetail',type:'GET',
					data:{personalCode,workDate},
					success:function(r){
						const tb=document.getElementById('trafficTableBody');
						const nm=document.getElementById('noTrafficMessage');
						const ts=document.getElementById('trafficSection');
						if (r.success&&r.data&&r.data.length>0) {
							tb.innerHTML='';
							r.data.forEach(function(item,i){
								const iT=item.in_time?fmtTime(item.in_time):'-';
								const oT=item.out_time?fmtTime(item.out_time):'-';
								const iType=(item.is_manual_in==="True"||item.is_manual_in===true)?'<span class="badge badge-info">دستی</span>':'<span class="badge badge-success">دستگاه</span>';
								const oType=item.is_manual_out?((item.is_manual_out==="True"||item.is_manual_out===true)?'<span class="badge badge-info">دستی</span>':'<span class="badge badge-success">دستگاه</span>'):'-';
								tb.innerHTML+=`<tr><td class="text-center">${i+1}</td><td class="text-center fw-bold text-primary">${iT}</td><td class="text-center">${iType}</td><td class="text-center fw-bold text-danger">${oT}</td><td class="text-center">${oType}</td><td class="text-center fw-bold">${toHM(item.duration_hours)}</td></tr>`;
							});
							ts.classList.remove('d-none'); nm.classList.add('d-none');
						} else { ts.classList.add('d-none'); nm.classList.remove('d-none'); }
						document.getElementById('detailSpinner').classList.add('d-none');
						document.getElementById('detailContent').classList.remove('d-none');
					},
					error:function(){
						document.getElementById('trafficSection').classList.add('d-none');
						const nm=document.getElementById('noTrafficMessage');
						nm.classList.remove('d-none'); nm.textContent='خطا در دریافت اطلاعات';
						document.getElementById('detailSpinner').classList.add('d-none');
						document.getElementById('detailContent').classList.remove('d-none');
					}
				});
			}
			function handleClick(raw) {
				if (!raw) return;
				var att;
				try { att=JSON.parse($('<textarea/>').html(raw).text()); } catch{return;}
				if (!att) return;
				if (att.redirectUrl) { window.location=att.redirectUrl; return; }
				showDetail(att.userId,att.personalCode,att.workDate,att.jalaliDate,att.fullName,att.groupName,
						   att.shiftStart,att.shiftEnd,att.firstEnter,att.lastExit,
						   att.totalPresentMins,att.delayMins,att.earlyExitMins,att.deficitMins,
						   att.approvedOtMins,att.pendingOtMins,att.status,att.workDateGreg);
			}
			/* دسکتاپ */
			$('.att-grid').on('click','.att-day-clickable',function(){ handleClick($(this).attr('data-attendance')); });
			/* موبایل */
			$('.mob-list').on('click','.mob-day.is-clickable',function(e){
				if ($(e.target).closest('a').length) return;
				handleClick($(this).attr('data-attendance'));
			});
		</script>
	}
